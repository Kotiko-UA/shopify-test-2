{% liquid
  assign hero_image_loading = 'lazy'
  assign hero_fetchpriority = ''

  if section.settings.prioritize_image
    assign hero_image_loading = 'eager'
    assign hero_fetchpriority = 'high'
  endif
%}

<section
  class="hero hero--image-{{ section.settings.image_position }}"
  style="
    --hero-background: {{ section.settings.background_color }};
    --hero-padding: {{ section.settings.padding }}px;
  "
>
  <div class="hero__content">
    {% if section.settings.eyebrow != blank %}
      <p class="hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1>{{ section.settings.heading | escape }}</h1>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="hero__description">
        {{ section.settings.description }}
      </div>
    {% endif %}

    <div class="hero__actions">
      {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
        {% render 'main-button',
          label: section.settings.primary_label,
          url: section.settings.primary_link,
          variant: section.settings.primary_variant
        %}
      {% endif %}

      {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
        {% render 'main-button',
          label: section.settings.secondary_label,
          url: section.settings.secondary_link,
          variant: 'secondary'
        %}
      {% endif %}
    </div>
  </div>

  {% if section.settings.image != blank %}
    {% render 'image',
      class: 'hero__image',
      image: section.settings.image,
      alt: section.settings.heading,
      loading: hero_image_loading,
      fetchpriority: hero_fetchpriority,
      width: 1200,
      height: 900,
      crop: 'center',
      widths: '500, 750, 1000, 1200',
      sizes: '(min-width: 990px) 48vw, 100vw'
    %}
  {% endif %}
</section>

{% stylesheet %}
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: center;
    padding: var(--hero-padding) 0;
    background-color: var(--hero-background);
  }

  .hero--image-left .hero__content {
    order: 2;
  }

  .hero__content {
    display: grid;
    gap: 1rem;
  }

  .hero__eyebrow {
    margin: 0;
    color: rgb(92, 95, 98);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 0.98;
  }

  .hero__description {
    max-width: 62ch;
    color: rgb(92, 95, 98);
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .hero__actions .main-button {
    margin-top: 0;
  }

  .hero__image img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
  }

  @media screen and (max-width: 749px) {
    .hero {
      grid-template-columns: 1fr;
      padding: calc(var(--hero-padding) * 0.65) 0;
    }

    .hero--image-left .hero__content {
      order: initial;
    }

    .hero h1 {
      max-width: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "New collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Build your next storefront"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Use this section for a strong first impression, campaign landing page, or featured collection intro.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "options": [
        { "value": "right", "label": "t:options.position.right" },
        { "value": "left", "label": "t:options.position.left" }
      ],
      "default": "right"
    },
    {
      "type": "checkbox",
      "id": "prioritize_image",
      "label": "t:labels.prioritize_image",
      "default": true
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "t:labels.primary_button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "t:labels.primary_button_link"
    },
    {
      "type": "select",
      "id": "primary_variant",
      "label": "t:labels.button_variant",
      "options": [
        { "value": "primary", "label": "t:general.primary" },
        { "value": "accent", "label": "t:general.accent" }
      ],
      "default": "primary"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "t:labels.secondary_button_label"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "t:labels.secondary_button_link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#f6f6f7"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "t:labels.padding",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [{ "name": "t:general.hero" }]
}
{% endschema %}
