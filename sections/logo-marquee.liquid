<section
  class="logo-marquee logo-marquee--{{ section.settings.direction }}"
  style="--logo-marquee-speed: {{ section.settings.speed }}s;"
>
  {% render 'section-header',
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  {% if section.blocks.size > 0 %}
    <div class="logo-marquee__viewport">
      <div class="logo-marquee__track">
        {% for repeat_index in (1..2) %}
          {% for block in section.blocks %}
            <div class="logo-marquee__item" {{ block.shopify_attributes }}>
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" aria-label="{{ block.settings.title | escape }}">
              {% endif %}

              {% if block.settings.logo != blank %}
                {% render 'image',
                  class: 'logo-marquee__logo',
                  image: block.settings.logo,
                  alt: block.settings.title,
                  width: 240,
                  widths: '120, 180, 240',
                  sizes: '160px'
                %}
              {% elsif block.settings.title != blank %}
                <span class="logo-marquee__text">{{ block.settings.title | escape }}</span>
              {% endif %}

              {% if block.settings.link != blank %}
                </a>
              {% endif %}
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  {% elsif request.design_mode %}
    <p class="logo-marquee__empty">{{ 'sections.logo_marquee.empty' | t }}</p>
  {% endif %}
</section>

{% stylesheet %}
  .logo-marquee {
    padding-block: 2.5rem;
  }

  .logo-marquee__viewport {
    overflow: hidden;
    border-block: 1px solid rgb(220, 220, 220);
  }

  .logo-marquee__track {
    display: flex;
    width: max-content;
    animation: logo-marquee-scroll var(--logo-marquee-speed) linear infinite;
  }

  .logo-marquee--right .logo-marquee__track {
    animation-direction: reverse;
  }

  .logo-marquee__viewport:hover .logo-marquee__track {
    animation-play-state: paused;
  }

  .logo-marquee__item {
    display: grid;
    place-items: center;
    min-width: 180px;
    padding: 1.25rem 2rem;
  }

  .logo-marquee__logo img {
    max-height: 56px;
    object-fit: contain;
  }

  .logo-marquee__text {
    font-weight: 700;
  }

  .logo-marquee__empty {
    padding: 1rem;
    border: 1px dashed rgb(180, 180, 180);
    border-radius: 6px;
    color: rgb(92, 95, 98);
  }

  @keyframes logo-marquee-scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-marquee__track {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.logo_marquee",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:labels.animation_speed",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:labels.direction",
      "options": [
        { "value": "left", "label": "t:options.direction.left" },
        { "value": "right", "label": "t:options.direction.right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "t:general.logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "t:labels.logo"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Brand"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.logo_marquee",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
