<section class="comparison-table">
  {% render 'section-header',
    eyebrow: section.settings.eyebrow,
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  <div class="comparison-table__table" role="table">
    <div class="comparison-table__row comparison-table__row--header" role="row">
      <div role="columnheader">{{ section.settings.feature_column | escape }}</div>
      <div role="columnheader">{{ section.settings.first_column | escape }}</div>
      <div role="columnheader">{{ section.settings.second_column | escape }}</div>
    </div>

    {% for block in section.blocks %}
      <div class="comparison-table__row" role="row" {{ block.shopify_attributes }}>
        <div role="cell">{{ block.settings.feature | escape }}</div>
        <div role="cell">{{ block.settings.first_value }}</div>
        <div role="cell">{{ block.settings.second_value }}</div>
      </div>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .comparison-table {
    padding-block: 3rem;
  }

  .comparison-table__table {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
  }

  .comparison-table__row {
    display: grid;
    grid-template-columns: minmax(140px, 1fr) repeat(2, minmax(140px, 1fr));
  }

  .comparison-table__row > * {
    padding: 1rem;
    border-top: 1px solid rgb(220, 220, 220);
  }

  .comparison-table__row > * + * {
    border-left: 1px solid rgb(220, 220, 220);
  }

  .comparison-table__row--header {
    background-color: rgb(246, 246, 247);
    font-weight: 700;
  }

  .comparison-table__row--header > * {
    border-top: 0;
  }

  @media screen and (max-width: 749px) {
    .comparison-table__table {
      overflow-x: auto;
    }

    .comparison-table__row {
      min-width: 620px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.comparison_table",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Compare options"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "text",
      "id": "feature_column",
      "label": "t:labels.feature_column",
      "default": "Feature"
    },
    {
      "type": "text",
      "id": "first_column",
      "label": "t:labels.first_column",
      "default": "Option A"
    },
    {
      "type": "text",
      "id": "second_column",
      "label": "t:labels.second_column",
      "default": "Option B"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "t:general.row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "t:labels.feature",
          "default": "Feature name"
        },
        {
          "type": "richtext",
          "id": "first_value",
          "label": "t:labels.first_value",
          "default": "<p>Add details.</p>"
        },
        {
          "type": "richtext",
          "id": "second_value",
          "label": "t:labels.second_value",
          "default": "<p>Add details.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.comparison_table",
      "blocks": [
        { "type": "row" },
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
