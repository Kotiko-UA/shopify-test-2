{% assign newsletter_promo_form_id = 'NewsletterPromoForm-' | append: section.id %}

<section
  class="newsletter-promo newsletter-promo--{{ section.settings.image_position }}"
  style="--newsletter-promo-background: {{ section.settings.background_color }};"
>
  <div class="newsletter-promo__content">
    {% render 'section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      text: section.settings.description,
      alignment: 'left'
    %}

    {% form 'customer', id: newsletter_promo_form_id, class: 'newsletter-promo__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {% if form.posted_successfully? %}
        <p class="newsletter-promo__success" role="status" tabindex="-1" autofocus>
          {{ 'newsletter.success' | t }}
        </p>
      {% endif %}

      {% if form.errors %}
        <div class="newsletter-promo__errors" role="alert" tabindex="-1" autofocus>
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <label for="{{ newsletter_promo_form_id }}-email">{{ 'newsletter.email' | t }}</label>
      <div class="newsletter-promo__row">
        <input
          id="{{ newsletter_promo_form_id }}-email"
          type="email"
          name="contact[email]"
          value="{{ form.email | escape }}"
          placeholder="{{ 'newsletter.placeholder' | t }}"
          autocomplete="email"
          required
        >
        <button type="submit">{{ section.settings.button_label | escape }}</button>
      </div>
    {% endform %}
  </div>

  {% if section.settings.image != blank %}
    {% render 'image',
      class: 'newsletter-promo__image',
      image: section.settings.image,
      alt: section.settings.heading,
      width: 1000,
      height: 750,
      crop: 'center',
      widths: '400, 650, 850, 1000',
      sizes: '(min-width: 990px) 44vw, 100vw'
    %}
  {% endif %}
</section>

{% stylesheet %}
  .newsletter-promo {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.8fr);
    gap: 2rem;
    align-items: center;
    padding: 2rem;
    border-radius: 8px;
    background-color: var(--newsletter-promo-background);
  }

  .newsletter-promo--left .newsletter-promo__content {
    order: 2;
  }

  .newsletter-promo__content {
    display: grid;
    gap: 1rem;
  }

  .newsletter-promo .section-header {
    margin-bottom: 0;
  }

  .newsletter-promo__form {
    display: grid;
    gap: 0.75rem;
  }

  .newsletter-promo__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
  }

  .newsletter-promo input {
    min-height: 44px;
    min-width: 0;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .newsletter-promo button {
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background-color: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .newsletter-promo__success,
  .newsletter-promo__errors {
    padding: 0.75rem 1rem;
    border-radius: 4px;
  }

  .newsletter-promo__success {
    border: 1px solid rgb(0, 128, 96);
    color: rgb(0, 128, 96);
  }

  .newsletter-promo__errors {
    border: 1px solid rgb(180, 38, 38);
    color: rgb(180, 38, 38);
  }

  .newsletter-promo__image img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
  }

  @media screen and (max-width: 749px) {
    .newsletter-promo {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }

    .newsletter-promo--left .newsletter-promo__content {
      order: initial;
    }

    .newsletter-promo__row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter_promo",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Get the latest drops and offers"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Invite customers to subscribe with a stronger visual treatment than the compact newsletter section.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "options": [
        { "value": "right", "label": "t:options.position.right" },
        { "value": "left", "label": "t:options.position.left" }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Subscribe"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#f6f6f7"
    }
  ],
  "presets": [{ "name": "t:general.newsletter_promo" }]
}
{% endschema %}
