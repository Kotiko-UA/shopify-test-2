<script src="{{ 'announcement-bar.js' | asset_url }}" defer></script>

<section
  class="announcement-bar full-width{% if section.settings.enable_marquee %} announcement-bar--marquee{% endif %}"
  data-announcement-bar
  data-section-id="{{ section.id }}"
  data-rotation-interval="{{ section.settings.rotation_interval | times: 1000 }}"
  data-marquee="{{ section.settings.enable_marquee }}"
  style="--announcement-background: {{ section.settings.background_color }}; --announcement-foreground: {{ section.settings.text_color }}; --announcement-speed: {{ section.settings.marquee_speed }}s;"
>
  <div class="announcement-bar__track">
    {% for copy_index in (1..2) %}
      <div class="announcement-bar__group" {% if copy_index == 2 %}aria-hidden="true"{% endif %}>
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <div
              class="announcement-bar__message"
              data-announcement-message
              data-start="{{ block.settings.start_datetime | escape }}"
              data-end="{{ block.settings.end_datetime | escape }}"
              {% unless forloop.first %}hidden{% endunless %}
              {% if copy_index == 1 %}{{ block.shopify_attributes }}{% endif %}
            >
              {% if block.settings.link != blank %}<a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>{% else %}<span>{{ block.settings.text | escape }}</span>{% endif %}
            </div>
          {% endfor %}
        {% else %}
          <div class="announcement-bar__message" data-announcement-message>
            {% if section.settings.link != blank %}<a href="{{ section.settings.link }}">{{ section.settings.text | escape }}</a>{% else %}<span>{{ section.settings.text | escape }}</span>{% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  {% if section.settings.dismissible %}
    <button class="announcement-bar__dismiss" type="button" data-announcement-dismiss aria-label="{{ 'accessibility.close' | t }}">&times;</button>
  {% endif %}
</section>

{% stylesheet %}
  .announcement-bar { position: relative; overflow: hidden; padding: 0.6rem 2.5rem; background: var(--announcement-background); color: var(--announcement-foreground); text-align: center; }
  .announcement-bar[hidden] { display: none; }
  .announcement-bar a { color: inherit; text-decoration: none; }
  .announcement-bar__track { display: flex; justify-content: center; }
  .announcement-bar__group { display: flex; flex: 0 0 auto; justify-content: center; }
  .announcement-bar:not(.announcement-bar--marquee) .announcement-bar__group[aria-hidden='true'] { display: none; }
  .announcement-bar__message { flex: 0 0 auto; padding-inline: 2rem; font-size: 0.9rem; font-weight: 700; }
  .announcement-bar--marquee .announcement-bar__track { justify-content: flex-start; width: max-content; animation: announcement-scroll var(--announcement-speed) linear infinite; }
  .announcement-bar--marquee .announcement-bar__message { display: block !important; }
  .announcement-bar--marquee .announcement-bar__message[data-scheduled='false'] { display: none !important; }
  .announcement-bar__dismiss { position: absolute; top: 50%; right: 0.75rem; border: 0; background: transparent; color: inherit; font-size: 1.4rem; transform: translateY(-50%); cursor: pointer; }
  @keyframes announcement-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .announcement-bar--marquee .announcement-bar__track { animation: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.announcement_bar",
  "enabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "text", "id": "text", "label": "t:labels.legacy_text", "default": "Free shipping on orders over $100" },
    { "type": "url", "id": "link", "label": "t:labels.legacy_link" },
    { "type": "checkbox", "id": "enable_marquee", "label": "t:labels.enable_marquee", "default": false },
    { "type": "range", "id": "marquee_speed", "label": "t:labels.marquee_speed", "min": 10, "max": 60, "step": 5, "unit": "s", "default": 25 },
    { "type": "range", "id": "rotation_interval", "label": "t:labels.rotation_interval", "min": 2, "max": 12, "step": 1, "unit": "s", "default": 5 },
    { "type": "checkbox", "id": "dismissible", "label": "t:labels.dismissible", "default": false },
    { "type": "color", "id": "background_color", "label": "t:labels.background", "default": "#202223" },
    { "type": "color", "id": "text_color", "label": "t:labels.text_color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "t:general.announcement_message",
      "settings": [
        { "type": "text", "id": "text", "label": "t:labels.text", "default": "Announcement message" },
        { "type": "url", "id": "link", "label": "t:labels.link" },
        { "type": "text", "id": "start_datetime", "label": "t:labels.start_datetime", "info": "Optional ISO date, for example 2026-12-01T09:00:00+02:00" },
        { "type": "text", "id": "end_datetime", "label": "t:labels.end_datetime", "info": "Optional ISO date, for example 2026-12-31T23:59:00+02:00" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{ "name": "t:general.announcement_bar", "blocks": [{ "type": "message" }] }]
}
{% endschema %}
