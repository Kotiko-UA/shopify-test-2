{% comment %}
  Renders a reusable contact form section.

  Shopify sends contact form submissions to the merchant using the Liquid
  `form` tag with the `contact` type.

  https://shopify.dev/docs/storefronts/themes/customer-engagement/add-contact-form
{% endcomment %}

{% assign contact_form_id = 'ContactForm-' | append: section.id %}

<section class="contact-form-section">
  <div class="contact-form-section__header">
    {% if section.settings.heading != blank %}
      <h1>{{ section.settings.heading | escape }}</h1>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="contact-form-section__description">
        {{ section.settings.description }}
      </div>
    {% endif %}
  </div>

  {% form 'contact', id: contact_form_id, class: 'contact-form' %}
    {% if form.posted_successfully? %}
      <p class="contact-form__success" tabindex="-1" autofocus>
        {{ 'contact.success' | t }}
      </p>
    {% endif %}

    {% if form.errors %}
      <div class="contact-form__errors" tabindex="-1" autofocus>
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div class="contact-form__grid">
      <div class="contact-form__field">
        <label for="{{ contact_form_id }}-name">{{ 'contact.name' | t }}</label>
        <input
          id="{{ contact_form_id }}-name"
          type="text"
          name="contact[name]"
          value="{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.name | escape }}{% endif %}"
          autocomplete="name"
        >
      </div>

      <div class="contact-form__field">
        <label for="{{ contact_form_id }}-email">{{ 'contact.email' | t }}</label>
        <input
          id="{{ contact_form_id }}-email"
          type="email"
          name="contact[email]"
          value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}"
          autocomplete="email"
          spellcheck="false"
          autocapitalize="off"
          required
        >
      </div>
    </div>

    {% if section.settings.show_phone %}
      <div class="contact-form__field">
        <label for="{{ contact_form_id }}-phone">{{ 'contact.phone' | t }}</label>
        <input
          id="{{ contact_form_id }}-phone"
          type="tel"
          name="contact[phone]"
          value="{{ form.phone | escape }}"
          autocomplete="tel"
        >
      </div>
    {% endif %}

    {% if section.settings.show_subject %}
      <div class="contact-form__field">
        <label for="{{ contact_form_id }}-subject">{{ 'contact.subject' | t }}</label>
        <select id="{{ contact_form_id }}-subject" name="contact[subject]">
          <option value="{{ 'contact.subject_options.general' | t }}">
            {{ 'contact.subject_options.general' | t }}
          </option>
          <option value="{{ 'contact.subject_options.order' | t }}">
            {{ 'contact.subject_options.order' | t }}
          </option>
          <option value="{{ 'contact.subject_options.shipping' | t }}">
            {{ 'contact.subject_options.shipping' | t }}
          </option>
          <option value="{{ 'contact.subject_options.returns' | t }}">
            {{ 'contact.subject_options.returns' | t }}
          </option>
          <option value="{{ 'contact.subject_options.other' | t }}">
            {{ 'contact.subject_options.other' | t }}
          </option>
        </select>
      </div>
    {% endif %}

    <div class="contact-form__field">
      <label for="{{ contact_form_id }}-body">{{ 'contact.message' | t }}</label>
      <textarea id="{{ contact_form_id }}-body" name="contact[body]" rows="6" required>{{ form.body | escape }}</textarea>
    </div>

    <button class="contact-form__submit" type="submit">{{ 'contact.submit' | t }}</button>
  {% endform %}
</section>

{% stylesheet %}
  .contact-form-section {
    width: min(100% - 2rem, 760px);
    margin-inline: auto;
    padding-block: 2rem;
  }

  .contact-form-section__header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .contact-form-section__description {
    color: rgb(92, 95, 98);
    line-height: 1.6;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .contact-form__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-form__field {
    display: grid;
    gap: 0.35rem;
  }

  .contact-form__field label {
    font-weight: 700;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form__success {
    padding: 0.75rem 1rem;
    border: 1px solid rgb(0, 128, 96);
    border-radius: 4px;
    color: rgb(0, 128, 96);
  }

  .contact-form__errors {
    padding: 0.75rem 1rem;
    border: 1px solid rgb(180, 38, 38);
    border-radius: 4px;
    color: rgb(180, 38, 38);
  }

  .contact-form__submit {
    justify-self: start;
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  @media screen and (max-width: 749px) {
    .contact-form__grid {
      grid-template-columns: 1fr;
    }

    .contact-form__submit {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.contact_form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Contact us"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Have a question? Send us a message and we will get back to you.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "t:labels.show_phone",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_subject",
      "label": "t:labels.show_subject",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:general.contact_form"
    }
  ]
}
{% endschema %}
