{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_media = current_variant.featured_media | default: product.featured_media %}
{% assign thumbnail_limit = section.settings.thumbnail_limit | default: 8 %}

<div class="product-page">
  <div class="product-images">
    {% if featured_media %}
      <div class="product-gallery" data-product-gallery>
        <div class="product-gallery__media-list">
          {% for media in product.media %}
            {% assign is_active_media = false %}
            {% if media.id == featured_media.id %}
              {% assign is_active_media = true %}
            {% endif %}

            <div
              class="product-gallery__media product-gallery__media--{{ media.media_type }}"
              data-product-gallery-media
              data-media-id="{{ media.id }}"
              {% unless is_active_media %}
                hidden
              {% endunless %}
            >
              {% case media.media_type %}
                {% when 'image' %}
                  <button
                    class="product-gallery__zoom-trigger"
                    type="button"
                    data-product-gallery-zoom
                    data-zoom-src="{{ media | image_url: width: 2000 }}"
                    data-zoom-alt="{{ media.alt | default: product.title | escape }}"
                    aria-label="{{ 'products.gallery.zoom_image' | t: title: product.title | escape }}"
                  >
                    {{
                      media
                      | image_url: width: 1200
                      | image_tag:
                        alt: media.alt,
                        loading: 'eager',
                        fetchpriority: 'high',
                        widths: '400, 600, 800, 1000, 1200',
                        sizes: '(min-width: 990px) 50vw, 100vw'
                    }}
                  </button>
                {% when 'video' %}
                  {{ media | video_tag: controls: true, preload: 'metadata', image_size: '1200x' }}
                {% when 'external_video' %}
                  {{ media | external_video_tag }}
                {% when 'model' %}
                  {{ media | model_viewer_tag: reveal: 'interaction', toggleable: true }}
              {% endcase %}
            </div>
          {% endfor %}
        </div>

        {% if section.settings.show_thumbnails != false and product.media.size > 1 %}
          <div class="product-thumbnails" aria-label="{{ 'products.gallery.thumbnails' | t }}">
            {% for media in product.media limit: thumbnail_limit %}
              {% assign is_active_thumbnail = false %}
              {% if media.id == featured_media.id %}
                {% assign is_active_thumbnail = true %}
              {% endif %}

              <button
                class="product-thumbnail{% if is_active_thumbnail %} product-thumbnail--active{% endif %}"
                type="button"
                aria-label="{{ 'products.gallery.view_media' | t: index: forloop.index, title: product.title | escape }}"
                aria-current="{% if is_active_thumbnail %}true{% else %}false{% endif %}"
                data-product-gallery-thumbnail
                data-media-id="{{ media.id }}"
              >
                {{
                  media.preview_image
                  | image_url: width: 160, height: 160, crop: 'center'
                  | image_tag: alt: '', loading: 'lazy', widths: '80, 120, 160', sizes: '80px'
                }}
                {% unless media.media_type == 'image' %}
                  <span class="product-thumbnail__type">{{ media.media_type | replace: '_', ' ' }}</span>
                {% endunless %}
              </button>
            {% endfor %}
          </div>
        {% endif %}

        <dialog class="product-gallery__dialog" data-product-gallery-dialog>
          <button
            class="product-gallery__dialog-close"
            type="button"
            data-product-gallery-dialog-close
            aria-label="{{ 'accessibility.close' | t }}"
          >
            &times;
          </button>
          <img data-product-gallery-dialog-image alt="" width="2000" height="2000">
        </dialog>
      </div>
    {% endif %}
  </div>

  <div class="product-details{% if section.settings.sticky_info %} product-details--sticky{% endif %}">
    <div class="product-info">
      {% if section.settings.show_vendor and product.vendor != blank %}
        <p class="product-vendor">{{ product.vendor }}</p>
      {% endif %}
      <h1>{{ product.title }}</h1>
      <div class="product-price">
        <span class="product-price__current" data-product-price>
          {{ current_variant.price | money }}
        </span>
        <s
          class="product-price__compare"
          data-product-compare-price
          {% unless current_variant.compare_at_price > current_variant.price %}
            hidden
          {% endunless %}
        >
          {{ current_variant.compare_at_price | money }}
        </s>
      </div>

      {% if section.settings.show_inventory %}
        <p
          class="product-inventory"
          data-product-inventory
          data-in-stock-text="{{ 'products.in_stock' | t | escape }}"
          data-low-stock-template="{{ 'products.low_stock' | t: count: 'COUNT' | escape }}"
          data-out-of-stock-text="{{ 'products.sold_out' | t | escape }}"
          data-threshold="{{ section.settings.low_inventory_threshold }}"
        >
          {% if current_variant.available %}
            {% if current_variant.inventory_management and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= section.settings.low_inventory_threshold %}
              {{ 'products.low_stock' | t: count: current_variant.inventory_quantity }}
            {% else %}
              {{ 'products.in_stock' | t }}
            {% endif %}
          {% else %}
            {{ 'products.sold_out' | t }}
          {% endif %}
        </p>
      {% endif %}

      <div class="product-description">
        {{ product.description }}
      </div>
    </div>

    <div class="product-form">
      {% assign adding_text = 'cart.adding' | t %}
      {% assign added_text = 'cart.added' | t %}
      {% assign error_text = 'cart.error' | t %}
      {% assign add_to_cart_text = 'products.add_to_cart' | t %}
      {% assign sold_out_text = 'products.sold_out' | t %}
      {% assign unavailable_text = 'products.unavailable' | t %}
      {% form 'product',
        product,
        class: 'js-product-form',
        data-product-main-form: '',
        data-currency: localization.country.currency.iso_code,
        data-add-to-cart-text: add_to_cart_text,
        data-sold-out-text: sold_out_text,
        data-unavailable-text: unavailable_text,
        data-adding-text: adding_text,
        data-added-text: added_text,
        data-error-text: error_text
      %}
        {% if form.errors %}
          <div class="product-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

        {% unless product.has_only_default_variant %}
          <div class="product-options">
            {% for option in product.options_with_values %}
              <fieldset class="product-option" data-product-option data-option-position="{{ option.position }}">
                <legend>{{ option.name | escape }}</legend>
                <div class="product-option__values">
                  {% for value in option.values %}
                    {% assign option_id = 'ProductOption-' | append: section.id | append: '-' | append: option.position | append: '-' | append: forloop.index %}
                    <input
                      id="{{ option_id }}"
                      class="product-option__input"
                      type="radio"
                      name="options[{{ option.name | escape }}]"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}
                        checked
                      {% endif %}
                    >
                    <label class="product-option__label" for="{{ option_id }}">{{ value }}</label>
                  {% endfor %}
                </div>
              </fieldset>
            {% endfor %}
          </div>
        {% endunless %}

        <label for="ProductQuantity-{{ section.id }}">{{ 'cart.quantity' | t }}</label>
        <input
          id="ProductQuantity-{{ section.id }}"
          class="product-form__quantity"
          type="number"
          name="quantity"
          min="1"
          value="1"
        >

        {% if section.settings.show_order_requests %}
          <div class="product-form__property">
            <label for="ProductOrderRequests-{{ section.id }}">
              {{ 'products.order_requests' | t }}
            </label>
            <textarea
              id="ProductOrderRequests-{{ section.id }}"
              name="properties[Order requests]"
              rows="3"
            ></textarea>
          </div>
        {% endif %}

        <input
          type="submit"
          value="{% if current_variant.available %}{{ 'products.add_to_cart' | t }}{% else %}{{ 'products.sold_out' | t }}{% endif %}"
          {% unless current_variant.available %}
            disabled
          {% endunless %}
        >
        <p class="product-form__message" role="status" aria-live="polite" hidden></p>
        {{ form | payment_button }}
      {% endform %}
    </div>

    {% if section.settings.size_guide_page != blank %}
      <details class="product-details__disclosure">
        <summary>{{ 'products.size_guide' | t }}</summary>
        <div class="product-details__disclosure-content rte">
          {{ section.settings.size_guide_page.content }}
        </div>
      </details>
    {% endif %}

    {% if section.settings.delivery_text != blank %}
      <div class="product-delivery">{{ section.settings.delivery_text }}</div>
    {% endif %}

    {% if section.settings.show_pickup_availability %}
      {% assign pickup_availabilities = current_variant.store_availabilities | where: 'pick_up_enabled', true %}
      <p
        class="product-pickup"
        data-product-pickup
        {% if pickup_availabilities.size == 0 %}
          hidden
        {% endif %}
      >
        {{ 'products.pickup_available' | t }}
      </p>
    {% endif %}

    <script type="application/json" data-product-variants>
      [
        {% for variant in product.variants %}
          {% assign variant_pickup_availabilities = variant.store_availabilities | where: 'pick_up_enabled', true %}
          {
            "id": {{ variant.id | json }},
            "available": {{ variant.available | json }},
            "price": {{ variant.price | json }},
            "compare_at_price": {{ variant.compare_at_price | json }},
            "options": {{ variant.options | json }},
            "featured_media_id": {{ variant.featured_media.id | json }},
            "inventory_quantity": {{ variant.inventory_quantity | json }},
            "inventory_management": {{ variant.inventory_management | json }},
            "inventory_policy": {{ variant.inventory_policy | json }},
            "pickup_available": {% if variant_pickup_availabilities.size > 0 %}true{% else %}false{% endif %}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ]
    </script>
  </div>
</div>

{% stylesheet %}
  .product-page {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 2rem;
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .product-details {
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .product-details--sticky {
    position: sticky;
    top: 1rem;
  }

  .product-info h1 {
    margin: 0;
    font-size: 3rem;
    line-height: 1.05;
  }

  .product-vendor {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
  }

  .product-price {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1rem;
    font-size: 1.25rem;
  }

  .product-price__current {
    font-weight: 700;
  }

  .product-price__compare {
    opacity: 0.6;
  }

  .product-description {
    max-width: 68ch;
    margin-top: 1.25rem;
    line-height: 1.5;
  }

  .product-gallery__media {
    overflow: hidden;
    border-radius: 8px;
    background: rgb(246, 246, 247);
  }

  .product-gallery__media[hidden] {
    display: none;
  }

  .product-gallery__media img,
  .product-gallery__media video,
  .product-gallery__media iframe,
  .product-gallery__media model-viewer {
    display: block;
    width: 100%;
    min-height: 420px;
    aspect-ratio: 1;
    border: 0;
    object-fit: contain;
  }

  .product-gallery__zoom-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: zoom-in;
  }

  .product-gallery__dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    box-sizing: border-box;
    width: min(94vw, 1200px);
    max-width: none;
    max-height: calc(100vh - 2rem);
    max-height: calc(100dvh - 2rem);
    margin: 0;
    padding: 2.5rem 1rem 1rem;
    border: 0;
    border-radius: 8px;
    background: white;
    overflow: hidden;
    transform: translate(-50%, -50%);
  }

  .product-gallery__dialog[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-gallery__dialog::backdrop {
    background: rgba(0, 0, 0, 0.72);
  }

  .product-gallery__dialog img {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: calc(100vh - 6rem);
    max-height: calc(100dvh - 6rem);
    object-fit: contain;
  }

  .product-gallery__dialog-close {
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    border: 0;
    background: transparent;
    font-size: 2rem;
    cursor: pointer;
  }

  .product-form > .js-product-form {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: rgb(250, 251, 251);
  }

  .product-form > .js-product-form input[type='text'],
  .product-form > .js-product-form input[type='number'],
  .product-form > .js-product-form textarea {
    min-height: 40px;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .product-form > .js-product-form textarea {
    min-height: 88px;
    resize: vertical;
  }

  .product-form__quantity {
    width: 80px;
  }

  .product-form__property {
    display: grid;
    gap: 0.4rem;
  }

  .product-form > .js-product-form input[type='submit'] {
    min-height: 44px;
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 4px;
    background-color: rgb(32, 34, 35);
    color: white;
    font-weight: 700;
    cursor: pointer;
  }

  .product-form > .js-product-form input[type='submit']:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .product-form__errors {
    margin-bottom: 1rem;
    color: rgb(190, 30, 30);
  }

  .product-options {
    display: grid;
    gap: 1rem;
  }

  .product-option {
    min-width: 0;
    padding: 0;
    border: 0;
  }

  .product-option legend {
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .product-option__values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-option__input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .product-option__label {
    min-width: 44px;
    padding: 0.55rem 0.8rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 999px;
    text-align: center;
    cursor: pointer;
  }

  .product-option__input:checked + .product-option__label {
    border-color: rgb(32, 34, 35);
    background: rgb(32, 34, 35);
    color: white;
  }

  .product-option__input:focus-visible + .product-option__label {
    outline: 2px solid currentcolor;
    outline-offset: 2px;
  }

  .product-inventory,
  .product-pickup {
    margin: 0.75rem 0 0;
    font-weight: 700;
  }

  .product-delivery,
  .product-details__disclosure {
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
  }

  .product-details__disclosure summary {
    font-weight: 700;
    cursor: pointer;
  }

  .product-details__disclosure-content {
    margin-top: 1rem;
  }

  .product-thumbnails {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    margin-top: 0.75rem;
    padding-bottom: 0.25rem;
  }

  .product-thumbnail {
    position: relative;
    flex: 0 0 80px;
    width: 80px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
  }

  .product-thumbnail--active {
    border-color: rgb(32, 34, 35);
  }

  .product-thumbnail img {
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 4px;
  }

  .product-thumbnail__type {
    position: absolute;
    right: 0.2rem;
    bottom: 0.2rem;
    left: 0.2rem;
    padding: 0.15rem;
    border-radius: 3px;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    font-size: 0.6rem;
    text-transform: capitalize;
  }

  @media screen and (max-width: 749px) {
    .product-page {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .product-details--sticky {
      position: static;
    }

    .product-gallery__media img,
    .product-gallery__media video,
    .product-gallery__media iframe,
    .product-gallery__media model-viewer {
      min-height: 280px;
    }

    .product-info h1 {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_thumbnails",
      "label": "t:labels.show_thumbnails",
      "default": true
    },
    {
      "type": "range",
      "id": "thumbnail_limit",
      "label": "t:labels.thumbnail_limit",
      "min": 4,
      "max": 20,
      "step": 4,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "sticky_info",
      "label": "t:labels.sticky_product_info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_inventory",
      "label": "t:labels.show_inventory",
      "default": true
    },
    {
      "type": "range",
      "id": "low_inventory_threshold",
      "label": "t:labels.low_inventory_threshold",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_order_requests",
      "label": "t:labels.show_order_requests",
      "default": true
    },
    {
      "type": "page",
      "id": "size_guide_page",
      "label": "t:labels.size_guide_page"
    },
    {
      "type": "richtext",
      "id": "delivery_text",
      "label": "t:labels.delivery_text"
    },
    {
      "type": "checkbox",
      "id": "show_pickup_availability",
      "label": "t:labels.show_pickup_availability",
      "default": true
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
