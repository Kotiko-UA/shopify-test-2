{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_image = current_variant.featured_image | default: product.featured_image %}

<div class="product-page">
  <div class="product-images">
    {% if featured_image %}
      {% render 'image', class: 'product-image product-image--featured', image: featured_image, width: 900 %}
    {% endif %}
    {% if product.images.size > 1 %}
      <div class="product-thumbnails">
        {% for image in product.images %}
          {% render 'image', class: 'product-thumbnail', image: image, width: 120 %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="product-info">
    {% if section.settings.show_vendor and product.vendor != blank %}
      <p class="product-vendor">{{ product.vendor }}</p>
    {% endif %}
    <h1>{{ product.title }}</h1>
    <div class="product-price">
      <span class="product-price__current">
        {{ current_variant.price | money }}
      </span>

      {% if current_variant.compare_at_price > current_variant.price %}
        <s class="product-price__compare">
          {{ current_variant.compare_at_price | money }}
        </s>
      {% endif %}
    </div>
    <div class="product-description">
      {{ product.description }}
    </div>
  </div>

  <div class="product-form">
    {% assign adding_text = 'cart.adding' | t %}
    {% assign added_text = 'cart.added' | t %}
    {% assign error_text = 'cart.error' | t %}
    {% form 'product',
      product,
      class: 'js-product-form',
      data-adding-text: adding_text,
      data-added-text: added_text,
      data-error-text: error_text
    %}
      {% if form.errors %}
        <div class="product-form__errors">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}
      <select name="id">
        {% for variant in product.variants %}
          <option
            value="{{ variant.id }}"
            {% if variant == current_variant %}
              selected="selected"
            {% endif %}
            {% unless variant.available %}
              disabled
            {% endunless %}
          >
            {{ variant.title }} - {{ variant.price | money }}
            {% unless variant.available %}
              - Sold out
            {% endunless %}
          </option>
        {% endfor %}
      </select>

      <input class="product-form__quantity" type="number" name="quantity" min="1" value="1">
      <div class="product-form__property">
        <label for="gift-message">Gift message</label>

        <input
          id="gift-message"
          type="text"
          name="properties[Gift message]"
        >
      </div>
      <input
        type="hidden"
        name="properties[_source]"
        value="product-page"
      >

      <input
        type="submit"
        value="{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}"
        {% unless current_variant.available %}
          disabled
        {% endunless %}
      >
      <p class="product-form__message" hidden></p>
      {{ form | payment_button }}
    {% endform %}
  </div>
</div>

{% stylesheet %}
  .product-page {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    grid-template-areas:
      'media info'
      'media form';
    gap: 2rem;
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .product-images {
    grid-area: media;
  }

  .product-info {
    grid-area: info;
    align-self: end;
  }

  .product-form {
    grid-area: form;
    align-self: start;
  }

  .product-info h1 {
    margin: 0;
    font-size: 3rem;
    line-height: 1.05;
  }

  .product-vendor {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
  }

  .product-price {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1rem;
    font-size: 1.25rem;
  }

  .product-price__current {
    font-weight: 700;
  }

  .product-price__compare {
    opacity: 0.6;
  }

  .product-description {
    max-width: 68ch;
    margin-top: 1.25rem;
    line-height: 1.5;
  }

  .product-image--featured img {
    border-radius: 8px;
  }

  .js-product-form {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: rgb(250, 251, 251);
  }

  .js-product-form select,
  .js-product-form input[type='text'],
  .js-product-form input[type='number'] {
    min-height: 40px;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .product-form__quantity {
    width: 80px;
  }

  .product-form__property {
    display: grid;
    gap: 0.4rem;
  }

  .js-product-form input[type='submit'] {
    min-height: 44px;
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 4px;
    background-color: rgb(32, 34, 35);
    color: white;
    font-weight: 700;
    cursor: pointer;
  }

  .js-product-form input[type='submit']:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .product-form__errors {
    margin-bottom: 1rem;
    color: rgb(190, 30, 30);
  }

  .product-thumbnails {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .product-thumbnail img {
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .product-page {
      grid-template-columns: 1fr;
      grid-template-areas:
        'media'
        'info'
        'form';
      gap: 1.25rem;
    }

    .product-info h1 {
      font-size: 2rem;
    }
  }

  .cart-toast {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 10;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: white;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .cart-toast[hidden] {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": true
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
