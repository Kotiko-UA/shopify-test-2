{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_image = current_variant.featured_image | default: product.featured_image %}

<div class="product-images">
  {% if featured_image %}
    {% render 'image', class: 'product-image product-image--featured', image: featured_image, width: 900 %}
  {% endif %}
  {% if product.images.size > 1 %}
    <div class="product-thumbnails">
      {% for image in product.images %}
        {% render 'image', class: 'product-thumbnail', image: image, width: 120 %}
      {% endfor %}
    </div>
  {% endif %}
</div>

<div class="product-info">
  {% if section.settings.show_vendor and product.vendor != blank %}
    <p class="product-vendor">{{ product.vendor }}</p>
  {% endif %}
  <h1>{{ product.title }}</h1>
  <div class="product-price">
    <span class="product-price__current">
      {{ current_variant.price | money }}
    </span>

    {% if current_variant.compare_at_price > current_variant.price %}
      <s class="product-price__compare">
        {{ current_variant.compare_at_price | money }}
      </s>
    {% endif %}
  </div>
  <p>{{ product.description }}</p>
</div>

<div class="product-form">
  {% form 'product', product %}
    {% if form.errors %}
      <div class="product-form__errors">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}
    <select name="id">
      {% for variant in product.variants %}
        <option
          value="{{ variant.id }}"
          {% if variant == current_variant %}
            selected="selected"
          {% endif %}
          {% unless variant.available %}
            disabled
          {% endunless %}
        >
          {{ variant.title }} - {{ variant.price | money }}
          {% unless variant.available %}
            - Sold out
          {% endunless %}
        </option>
      {% endfor %}
    </select>

    <input class="product-form__quantity" type="number" name="quantity" min="1" value="1">

    <input
      type="submit"
      value="{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}"
      {% unless current_variant.available %}
        disabled
      {% endunless %}
    >
    {{ form | payment_button }}
  {% endform %}
</div>

{% stylesheet %}
  .product-vendor {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
  }
  .product-price {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .product-price__current {
    font-weight: 700;
  }

  .product-price__compare {
    opacity: 0.6;
  }
  .product-form__quantity {
    width: 80px;
  }
  .product-form__errors {
    margin-bottom: 1rem;
    color: rgb(190, 30, 30);
  }
  .product-thumbnails {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .product-thumbnail img {
    aspect-ratio: 1;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": true
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
