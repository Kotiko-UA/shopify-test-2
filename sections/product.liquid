{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign featured_image = current_variant.featured_image | default: product.featured_image %}
{% assign thumbnail_limit = section.settings.thumbnail_limit | default: 8 %}

<div class="product-page">
  <div class="product-images">
    {% if featured_image %}
      <div class="product-gallery" data-product-gallery>
        <div class="image product-image product-image--featured" data-product-gallery-featured>
          {{
            featured_image
            | image_url: width: 900
            | image_tag:
              alt: product.title,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '400, 600, 800, 900',
              sizes: '(min-width: 990px) 50vw, 100vw'
          }}
        </div>

        {% if section.settings.show_thumbnails != false and product.images.size > 1 %}
          <div class="product-thumbnails" aria-label="{{ 'products.gallery.thumbnails' | t }}">
            {% for image in product.images limit: thumbnail_limit %}
              {% assign image_alt = image.alt | default: product.title %}
              {% assign gallery_image_height = 900 | times: image.height | divided_by: image.width %}
              {% assign is_active_thumbnail = false %}
              {% if image.id == featured_image.id %}
                {% assign is_active_thumbnail = true %}
              {% endif %}

              <button
                class="product-thumbnail{% if is_active_thumbnail %} product-thumbnail--active{% endif %}"
                type="button"
                aria-label="{{ 'products.gallery.view_image' | t: index: forloop.index, title: product.title | escape }}"
                aria-current="{% if is_active_thumbnail %}true{% else %}false{% endif %}"
                data-product-gallery-thumbnail
                data-gallery-src="{{ image | image_url: width: 900 }}"
                data-gallery-srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 900 }} 900w"
                data-gallery-sizes="(min-width: 990px) 50vw, 100vw"
                data-gallery-alt="{{ image_alt | escape }}"
                data-gallery-width="900"
                data-gallery-height="{{ gallery_image_height }}"
              >
                {{
                  image
                  | image_url: width: 160, height: 160, crop: 'center'
                  | image_tag: alt: '', loading: 'lazy', widths: '80, 120, 160', sizes: '80px'
                }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <div class="product-info">
    {% if section.settings.show_vendor and product.vendor != blank %}
      <p class="product-vendor">{{ product.vendor }}</p>
    {% endif %}
    <h1>{{ product.title }}</h1>
    <div class="product-price">
      <span class="product-price__current">
        {{ current_variant.price | money }}
      </span>

      {% if current_variant.compare_at_price > current_variant.price %}
        <s class="product-price__compare">
          {{ current_variant.compare_at_price | money }}
        </s>
      {% endif %}
    </div>
    <div class="product-description">
      {{ product.description }}
    </div>

  </div>

  <div class="product-form">
    {% assign adding_text = 'cart.adding' | t %}
    {% assign added_text = 'cart.added' | t %}
    {% assign error_text = 'cart.error' | t %}
    {% form 'product',
      product,
      class: 'js-product-form',
      data-adding-text: adding_text,
      data-added-text: added_text,
      data-error-text: error_text
    %}
      {% if form.errors %}
        <div class="product-form__errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}
      <select name="id">
        {% for variant in product.variants %}
          <option
            value="{{ variant.id }}"
            {% if variant == current_variant %}
              selected="selected"
            {% endif %}
            {% unless variant.available %}
              disabled
            {% endunless %}
          >
            {{ variant.title }} - {{ variant.price | money }}
            {% unless variant.available %}
              - Sold out
            {% endunless %}
          </option>
        {% endfor %}
      </select>

      <label class="visually-hidden" for="ProductQuantity-{{ section.id }}">
        {{ 'cart.quantity' | t }}
      </label>
      <input
        id="ProductQuantity-{{ section.id }}"
        class="product-form__quantity"
        type="number"
        name="quantity"
        min="1"
        value="1"
      >
      <div class="product-form__property">
        <label for="ProductOrderRequests-{{ section.id }}">
          {{ 'products.order_requests' | t }}
        </label>

        <textarea
          id="ProductOrderRequests-{{ section.id }}"
          name="properties[Order requests]"
          rows="3"
        ></textarea>
      </div>

      <input
        type="submit"
        value="{% if current_variant.available %}Add to cart{% else %}Sold out{% endif %}"
        {% unless current_variant.available %}
          disabled
        {% endunless %}
      >
      <p class="product-form__message" role="status" aria-live="polite" hidden></p>
      {{ form | payment_button }}
    {% endform %}
  </div>
</div>

{% stylesheet %}
  .product-page {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    grid-template-areas:
      'media info'
      'media form';
    gap: 2rem;
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .product-images {
    grid-area: media;
  }

  .product-info {
    grid-area: info;
    align-self: end;
  }

  .product-form {
    grid-area: form;
    align-self: start;
  }

  .product-info h1 {
    margin: 0;
    font-size: 3rem;
    line-height: 1.05;
  }

  .product-vendor {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.7;
  }

  .product-price {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 1rem;
    font-size: 1.25rem;
  }

  .product-price__current {
    font-weight: 700;
  }

  .product-price__compare {
    opacity: 0.6;
  }

  .product-description {
    max-width: 68ch;
    margin-top: 1.25rem;
    line-height: 1.5;
  }

  .product-image--featured img {
    border-radius: 8px;
  }

  .js-product-form {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: rgb(250, 251, 251);
  }

  .js-product-form select,
  .js-product-form input[type='text'],
  .js-product-form input[type='number'],
  .js-product-form textarea {
    min-height: 40px;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .js-product-form textarea {
    min-height: 88px;
    resize: vertical;
  }

  .product-form__quantity {
    width: 80px;
  }

  .product-form__property {
    display: grid;
    gap: 0.4rem;
  }

  .js-product-form input[type='submit'] {
    min-height: 44px;
    padding: 0.75rem 1rem;
    border: 0;
    border-radius: 4px;
    background-color: rgb(32, 34, 35);
    color: white;
    font-weight: 700;
    cursor: pointer;
  }

  .js-product-form input[type='submit']:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }

  .product-form__errors {
    margin-bottom: 1rem;
    color: rgb(190, 30, 30);
  }

  .product-thumbnails {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    margin-top: 0.75rem;
    padding-bottom: 0.25rem;
  }

  .product-thumbnail {
    flex: 0 0 80px;
    width: 80px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
  }

  .product-thumbnail--active {
    border-color: rgb(32, 34, 35);
  }

  .product-thumbnail img {
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .product-page {
      grid-template-columns: 1fr;
      grid-template-areas:
        'media'
        'info'
        'form';
      gap: 1.25rem;
    }

    .product-info h1 {
      font-size: 2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_thumbnails",
      "label": "t:labels.show_thumbnails",
      "default": true
    },
    {
      "type": "range",
      "id": "thumbnail_limit",
      "label": "t:labels.thumbnail_limit",
      "min": 4,
      "max": 20,
      "step": 4,
      "default": 8
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
