{% stylesheet %}
  .starter-library {
    display: grid;
    gap: 2.5rem;
    padding-block: 3rem;
  }

  .starter-library__hero {
    display: grid;
    gap: 1rem;
    max-width: 860px;
  }

  .starter-library__hero h1 {
    margin: 0;
    font-size: clamp(2.4rem, 6vw, 5rem);
    line-height: 1;
  }

  .starter-library__hero p {
    max-width: 70ch;
    color: rgb(92, 95, 98);
    line-height: 1.6;
  }

  .starter-library__eyebrow,
  .starter-library__heading p,
  .starter-library-example__type,
  .starter-library-example__meta > span,
  .starter-library-card > span {
    margin: 0;
    color: rgb(92, 95, 98);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .starter-library__route,
  .starter-library__note {
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background: rgb(250, 251, 251);
  }

  .starter-library__route {
    display: grid;
    gap: 0.4rem;
  }

  .starter-library__note {
    line-height: 1.55;
  }

  .starter-library__route span {
    color: rgb(92, 95, 98);
    font-size: 0.85rem;
  }

  .starter-library code {
    display: inline-block;
    min-width: 0;
    width: auto;
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
    white-space: normal;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    background: rgb(244, 244, 245);
    color: rgb(32, 34, 35);
    font-size: 0.85rem;
    line-height: 1.35;
    vertical-align: baseline;
  }

  .starter-library__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .starter-library__nav a {
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 4px;
    color: currentcolor;
    text-decoration: none;
  }

  .starter-library__summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
  }

  .starter-library__summary > div {
    display: grid;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
  }

  .starter-library__summary strong {
    font-size: 2rem;
    line-height: 1;
  }

  .starter-library__summary span {
    color: rgb(92, 95, 98);
  }

  .starter-library__examples {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .starter-library-example {
    display: grid;
    overflow: hidden;
    min-width: 0;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 16px;
    background: white;
    box-shadow: 0 14px 44px rgba(0, 0, 0, 0.06);
  }

  .starter-library-example__preview {
    display: grid;
    align-content: center;
    gap: 1rem;
    min-height: 250px;
    padding: 1.25rem;
    background:
      radial-gradient(circle at top left, rgba(32, 34, 35, 0.12), transparent 32%),
      linear-gradient(135deg, rgb(250, 251, 251), rgb(241, 242, 244));
  }

  .starter-library-example__preview--section {
    background:
      linear-gradient(135deg, rgba(32, 34, 35, 0.08), rgba(32, 34, 35, 0)),
      repeating-linear-gradient(90deg, rgb(248, 248, 249) 0 14px, rgb(243, 244, 246) 14px 28px);
  }

  .starter-library-example__preview--blog {
    background: linear-gradient(135deg, rgb(247, 249, 255), rgb(255, 255, 255));
  }

  .starter-library-example__preview--block {
    background: linear-gradient(135deg, rgb(255, 248, 237), rgb(255, 255, 255));
  }

  .starter-library-example__preview--faq {
    background: linear-gradient(135deg, rgb(245, 251, 247), rgb(255, 255, 255));
  }

  .starter-library-example__preview--form {
    background: linear-gradient(135deg, rgb(246, 247, 255), rgb(255, 255, 255));
  }

  .starter-library-example__preview--testimonials {
    background: linear-gradient(135deg, rgb(255, 248, 251), rgb(255, 255, 255));
  }

  .starter-library-example__type {
    justify-self: start;
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
  }

  .starter-library-example__reference {
    display: grid;
    gap: 0.85rem;
    padding: 1.25rem;
  }

  .starter-library-example__reference h3,
  .starter-library-example__reference p,
  .starter-library-example__meta p {
    margin: 0;
  }

  .starter-library-example__reference > p,
  .starter-library-example__meta p {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }

  .starter-library-example__meta {
    display: grid;
    gap: 0.4rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgb(220, 220, 220);
  }

  .starter-library-example__meta code {
    justify-self: start;
  }

  .starter-library-mini-section {
    padding: clamp(1.25rem, 5vw, 2rem);
    border: 1px solid rgba(32, 34, 35, 0.16);
    border-radius: 18px;
    background: linear-gradient(135deg, rgb(225, 243, 255), rgb(255, 255, 255));
  }

  .starter-library-mini-section__container {
    display: grid;
    gap: 0.5rem;
    width: min(100%, 360px);
    margin-inline: auto;
    padding: 1rem;
    border: 1px solid rgba(32, 34, 35, 0.14);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.82);
  }

  .starter-library-mini-section__container p {
    margin: 0;
    color: rgb(92, 95, 98);
    line-height: 1.45;
  }

  .starter-library-mini-blog {
    display: grid;
    gap: 0.75rem;
  }

  .starter-library-mini-blog > div,
  .starter-library-mini-blog article,
  .starter-library-mini-featured-blog {
    padding: 0.85rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.86);
  }

  .starter-library-mini-blog > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: space-between;
  }

  .starter-library-mini-blog span,
  .starter-library-mini-featured-blog small {
    color: rgb(92, 95, 98);
    font-size: 0.8rem;
  }

  .starter-library-mini-blog article {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 0.65rem;
  }

  .starter-library-mini-blog article > span {
    grid-row: span 2;
    min-height: 56px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgb(32, 34, 35), rgb(128, 130, 133));
  }

  .starter-library-mini-blog article p {
    margin: 0;
    color: rgb(92, 95, 98);
    font-size: 0.85rem;
    line-height: 1.35;
  }

  .starter-library-mini-featured-blog {
    display: grid;
    gap: 1rem;
  }

  .starter-library-mini-featured-blog header {
    display: grid;
    gap: 0.25rem;
  }

  .starter-library-mini-featured-blog > div {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .starter-library-mini-featured-blog > div span {
    min-height: 86px;
    border-radius: 10px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0) 45%, rgba(255, 255, 255, 0.92) 45%),
      linear-gradient(135deg, rgb(250, 203, 128), rgb(249, 119, 148));
    box-shadow: inset 0 0 0 1px rgba(32, 34, 35, 0.1);
  }

  .starter-library-mini-faq {
    display: grid;
    gap: 0.75rem;
  }

  .starter-library-mini-faq label {
    display: grid;
    gap: 0.35rem;
    font-weight: 700;
  }

  .starter-library-mini-faq input,
  .starter-library-mini-contact input:not([type='checkbox']),
  .starter-library-mini-contact textarea {
    width: 100%;
    padding: 0.55rem 0.65rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 6px;
    background: white;
    font: inherit;
  }

  .starter-library-mini-faq details {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.9);
  }

  .starter-library-mini-faq summary {
    display: flex;
    gap: 0.75rem;
    justify-content: space-between;
    padding: 0.85rem;
    font-weight: 700;
    cursor: pointer;
  }

  .starter-library-mini-faq summary::after {
    content: '+';
  }

  .starter-library-mini-faq details[open] summary::after {
    content: '-';
  }

  .starter-library-mini-faq p {
    margin: 0;
    padding: 0 0.85rem 0.85rem;
    color: rgb(92, 95, 98);
    line-height: 1.45;
  }

  .starter-library-mini-contact {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .starter-library-mini-contact label {
    display: grid;
    gap: 0.35rem;
    font-weight: 700;
  }

  .starter-library-mini-contact__full,
  .starter-library-mini-contact__consent,
  .starter-library-mini-contact button {
    grid-column: 1 / -1;
  }

  .starter-library-mini-contact__consent {
    display: flex !important;
    align-items: flex-start;
    font-weight: 400 !important;
  }

  .starter-library-mini-contact__consent input {
    margin-top: 0.25rem;
  }

  .starter-library-mini-contact button {
    justify-self: start;
    min-height: 40px;
    padding: 0.6rem 0.9rem;
    border: 1px solid rgb(32, 34, 35);
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
    font: inherit;
  }

  .starter-library-mini-testimonials {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .starter-library-mini-testimonials figure {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0.9rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.92);
  }

  .starter-library-mini-testimonials figure > div {
    color: rgb(32, 34, 35);
    letter-spacing: 0.08em;
  }

  .starter-library-mini-testimonials blockquote {
    margin: 0;
    color: rgb(60, 60, 60);
    line-height: 1.45;
  }

  .starter-library-mini-testimonials figcaption {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.1rem 0.55rem;
    align-items: center;
  }

  .starter-library-mini-testimonials figcaption span {
    display: inline-flex;
    grid-row: span 2;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .starter-library-mini-testimonials small {
    color: rgb(92, 95, 98);
  }

  .starter-library-live-list {
    display: grid;
    gap: 1.5rem;
  }

  .starter-library-live-card {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 18px;
    background: white;
    box-shadow: 0 14px 44px rgba(0, 0, 0, 0.06);
  }

  .starter-library-live-card__preview {
    padding: clamp(1rem, 3vw, 2rem);
    border-bottom: 1px solid rgb(220, 220, 220);
    background: linear-gradient(135deg, rgb(250, 251, 251), rgb(246, 246, 247));
  }

  .starter-library-live-card__reference {
    display: grid;
    gap: 0.75rem;
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .starter-library-live-card__reference > span {
    color: rgb(92, 95, 98);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .starter-library-live-card__reference h3,
  .starter-library-live-card__reference p,
  .starter-library-live-card__meta p {
    margin: 0;
  }

  .starter-library-live-card__reference > p,
  .starter-library-live-card__meta p {
    color: rgb(92, 95, 98);
    line-height: 1.55;
  }

  .starter-library-live-card__meta {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(260px, 1.1fr);
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgb(220, 220, 220);
  }

  .starter-library-live-card__meta > div {
    display: grid;
    align-content: start;
    gap: 0.45rem;
    min-width: 0;
  }

  .starter-library-live-card__meta code {
    justify-self: start;
  }

  .starter-library-demo-section {
    padding: clamp(1.25rem, 5vw, 3rem);
    border-radius: 18px;
    background:
      radial-gradient(circle at 10% 20%, rgba(88, 166, 255, 0.24), transparent 28%),
      linear-gradient(135deg, rgb(230, 246, 255), rgb(255, 255, 255));
  }

  .starter-library-demo-section__container {
    display: grid;
    gap: 0.75rem;
    width: min(100%, 980px);
    margin-inline: auto;
    padding: clamp(1rem, 3vw, 2rem);
    border: 1px solid rgba(32, 34, 35, 0.14);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.84);
  }

  .starter-library-demo-section__container p,
  .starter-library-demo-section__container h3 {
    margin: 0;
  }

  .starter-library-demo-section__container > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .starter-library-demo-section__container span,
  .starter-library-demo-logos span,
  .starter-library-demo-badges article,
  .starter-library-demo-countdown span,
  .starter-library-demo-tabs button {
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 999px;
    background: white;
  }

  .starter-library-demo-announcement {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 1rem;
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
  }

  .starter-library-demo-announcement a,
  .starter-library-demo-hero a,
  .starter-library-demo-media a {
    color: inherit;
  }

  .starter-library-demo-announcement button {
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
  }

  .starter-library-demo-hero {
    display: grid;
    gap: 1rem;
    min-height: 360px;
    align-content: end;
    padding: clamp(1.25rem, 5vw, 3rem);
    border-radius: 18px;
    color: white;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.05), rgba(0, 0, 0, 0.62)),
      linear-gradient(135deg, rgb(247, 186, 89), rgb(239, 92, 128));
  }

  .starter-library-demo-hero p,
  .starter-library-demo-hero h3,
  .starter-library-demo-media p,
  .starter-library-demo-media h3,
  .starter-library-demo-countdown strong,
  .starter-library-demo-newsletter p,
  .starter-library-demo-newsletter h3 {
    margin: 0;
  }

  .starter-library-demo-hero h3 {
    max-width: 12ch;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1;
  }

  .starter-library-demo-hero > div,
  .starter-library-demo-slider,
  .starter-library-demo-logos,
  .starter-library-demo-countdown > div,
  .starter-library-demo-tabs [role='tablist'] {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .starter-library-demo-hero a,
  .starter-library-demo-media a,
  .starter-library-demo-newsletter button,
  .starter-library-demo-contact button,
  .starter-library-demo-sticky-cart button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0.65rem 1rem;
    border: 1px solid currentcolor;
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
    text-decoration: none;
  }

  .starter-library-demo-products,
  .starter-library-demo-blog,
  .starter-library-demo-badges,
  .starter-library-demo-promo-grid,
  .starter-library-demo-collections,
  .starter-library-demo-reviews {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .starter-library-demo-products article,
  .starter-library-demo-blog article,
  .starter-library-demo-badges article,
  .starter-library-demo-promo-grid article,
  .starter-library-demo-collections article,
  .starter-library-demo-reviews figure {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 12px;
    background: white;
  }

  .starter-library-demo-products article > span,
  .starter-library-demo-blog article > span,
  .starter-library-demo-collections article > span {
    min-height: 150px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgb(238, 238, 238), rgb(248, 248, 248));
  }

  .starter-library-demo-products strong,
  .starter-library-demo-products small,
  .starter-library-demo-blog strong,
  .starter-library-demo-blog p,
  .starter-library-demo-collections strong,
  .starter-library-demo-collections small,
  .starter-library-demo-reviews blockquote,
  .starter-library-demo-reviews figcaption {
    margin: 0;
  }

  .starter-library-demo-products small,
  .starter-library-demo-blog p,
  .starter-library-demo-collections small,
  .starter-library-demo-reviews figcaption {
    color: rgb(92, 95, 98);
  }

  .starter-library-demo-slider > div {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    flex: 1;
  }

  .starter-library-demo-slider button,
  .starter-library-demo-tabs button {
    cursor: pointer;
  }

  .starter-library-demo-slider button {
    width: 44px;
    height: 44px;
    border: 1px solid rgb(32, 34, 35);
    border-radius: 999px;
    background: white;
  }

  .starter-library-demo-media {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(1rem, 4vw, 2rem);
    align-items: center;
  }

  .starter-library-demo-media > span {
    min-height: 320px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgb(210, 210, 210), rgb(248, 248, 248));
  }

  .starter-library-demo-media > div,
  .starter-library-demo-countdown,
  .starter-library-demo-newsletter,
  .starter-library-demo-tabs [role='tabpanel'] {
    display: grid;
    gap: 0.85rem;
  }

  .starter-library-demo-logos {
    justify-content: center;
    min-height: 120px;
  }

  .starter-library-demo-countdown {
    justify-items: center;
    padding: 2rem;
    border-radius: 18px;
    background: rgb(32, 34, 35);
    color: white;
  }

  .starter-library-demo-countdown span {
    display: grid;
    min-width: 90px;
    justify-items: center;
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 1.6rem;
    font-weight: 700;
  }

  .starter-library-demo-countdown small {
    font-size: 0.75rem;
    font-weight: 400;
    opacity: 0.72;
  }

  .starter-library-demo-faq {
    display: grid;
    gap: 0.75rem;
  }

  .starter-library-demo-faq details {
    border: 1px solid rgb(220, 220, 220);
    border-radius: 10px;
    background: white;
  }

  .starter-library-demo-faq summary {
    padding: 1rem;
    font-weight: 700;
    cursor: pointer;
  }

  .starter-library-demo-faq p {
    margin: 0;
    padding: 0 1rem 1rem;
    color: rgb(92, 95, 98);
  }

  .starter-library-demo-promo-grid article {
    min-height: 180px;
    align-content: end;
    color: white;
    background: linear-gradient(135deg, rgb(247, 186, 89), rgb(239, 92, 128));
  }

  .starter-library-demo-newsletter {
    max-width: 760px;
    margin-inline: auto;
    padding: 2rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 16px;
    background: white;
  }

  .starter-library-demo-newsletter--promo {
    max-width: none;
    color: white;
    background: linear-gradient(135deg, rgb(32, 34, 35), rgb(85, 87, 90));
  }

  .starter-library-demo-newsletter > div {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
  }

  .starter-library-demo-newsletter input,
  .starter-library-demo-contact input:not([type='checkbox']),
  .starter-library-demo-contact textarea {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 8px;
    font: inherit;
  }

  .starter-library-demo-contact {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    max-width: 840px;
    margin-inline: auto;
  }

  .starter-library-demo-contact label {
    display: grid;
    gap: 0.35rem;
    font-weight: 700;
  }

  .starter-library-demo-contact__full,
  .starter-library-demo-contact__consent,
  .starter-library-demo-contact button {
    grid-column: 1 / -1;
  }

  .starter-library-demo-contact__consent {
    display: flex !important;
    align-items: flex-start;
    font-weight: 400 !important;
  }

  .starter-library-demo-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
  }

  .starter-library-demo-table th,
  .starter-library-demo-table td {
    padding: 0.85rem;
    border: 1px solid rgb(220, 220, 220);
    text-align: left;
  }

  .starter-library-demo-table th {
    background: rgb(246, 246, 247);
  }

  .starter-library-demo-tabs {
    display: grid;
    gap: 1rem;
  }

  .starter-library-demo-tabs [role='tabpanel'] {
    padding: 1.25rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 12px;
    background: white;
  }

  .starter-library-demo-sticky-cart {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 999px;
    background: white;
    box-shadow: 0 16px 44px rgba(0, 0, 0, 0.12);
  }

  .starter-library-demo-sticky-cart > span {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgb(230, 230, 230), rgb(250, 250, 250));
  }

  .starter-library__guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
  }

  .starter-library-guide-card {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 12px;
    background: linear-gradient(135deg, rgb(250, 251, 251), white);
  }

  .starter-library-guide-card > span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
    font-weight: 700;
  }

  .starter-library-guide-card h3,
  .starter-library-guide-card p {
    margin: 0;
  }

  .starter-library-guide-card p {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }

  .starter-library__group {
    display: grid;
    gap: 1.25rem;
    scroll-margin-top: 2rem;
  }

  .starter-library__heading {
    display: grid;
    gap: 0.35rem;
  }

  .starter-library__heading h2 {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
  }

  .starter-library__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    min-width: 0;
  }

  .starter-library__grid--small {
    grid-template-columns: 1fr;
  }

  .starter-library-card {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background: white;
  }

  .starter-library-card > span {
    order: 1;
  }

  .starter-library-card h3 {
    order: 2;
  }

  .starter-library-card p {
    order: 3;
  }

  .starter-library-card code {
    order: 4;
    justify-self: start;
  }

  .starter-library-card code:first-of-type {
    margin-top: 0.25rem;
  }

  .starter-library-card--featured {
    border-color: rgb(32, 34, 35);
    background: rgb(250, 251, 251);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08);
  }

  .starter-library-card h3,
  .starter-library-card p {
    margin: 0;
  }

  .starter-library-card h3 {
    font-size: 1.1rem;
  }

  .starter-library-card p {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }

  .starter-library-modal-trigger {
    display: grid;
    gap: 0.15rem;
    width: fit-content;
    padding: 0.75rem 1rem;
    border: 1px solid rgb(32, 34, 35);
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .starter-library-modal-trigger small {
    opacity: 0.72;
    font-size: 0.75rem;
  }

  .starter-library__table {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
  }

  .starter-library__row {
    display: grid;
    grid-template-columns: minmax(140px, 0.6fr) minmax(220px, 0.9fr) minmax(240px, 1.5fr);
  }

  .starter-library__row > * {
    min-width: 0;
    padding: 0.85rem;
    border-top: 1px solid rgb(220, 220, 220);
  }

  .starter-library__row > * + * {
    border-left: 1px solid rgb(220, 220, 220);
  }

  .starter-library__row--head {
    background: rgb(246, 246, 247);
    font-weight: 700;
  }

  .starter-library__row--head > * {
    border-top: 0;
  }

  @media screen and (max-width: 749px) {
    .starter-library-mini-contact,
    .starter-library-mini-testimonials {
      grid-template-columns: 1fr;
    }

    .starter-library__table {
      overflow-x: auto;
    }

    .starter-library__row {
      min-width: 760px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Starter template library",
  "settings": [],
  "presets": [{ "name": "Starter template library" }]
}
{% endschema %}
