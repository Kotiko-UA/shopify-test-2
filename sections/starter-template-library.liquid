{% stylesheet %}
  .starter-library {
    display: grid;
    gap: 2.5rem;
    padding-block: 3rem;
  }

  .starter-library__hero {
    display: grid;
    gap: 1rem;
    max-width: 860px;
  }

  .starter-library__hero h1 {
    margin: 0;
    font-size: clamp(2.4rem, 6vw, 5rem);
    line-height: 1;
  }

  .starter-library__hero p {
    max-width: 70ch;
    color: rgb(92, 95, 98);
    line-height: 1.6;
  }

  .starter-library__eyebrow,
  .starter-library__heading p,
  .starter-library-card > span {
    margin: 0;
    color: rgb(92, 95, 98);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .starter-library__route,
  .starter-library__note {
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background: rgb(250, 251, 251);
  }

  .starter-library__route {
    display: grid;
    gap: 0.4rem;
  }

  .starter-library__note {
    line-height: 1.55;
  }

  .starter-library__route span {
    color: rgb(92, 95, 98);
    font-size: 0.85rem;
  }

  .starter-library code {
    display: inline-block;
    min-width: 0;
    width: auto;
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
    white-space: normal;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    background: rgb(244, 244, 245);
    color: rgb(32, 34, 35);
    font-size: 0.85rem;
    line-height: 1.35;
    vertical-align: baseline;
  }

  .starter-library__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .starter-library__nav a {
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 4px;
    color: currentcolor;
    text-decoration: none;
  }

  .starter-library__summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
  }

  .starter-library__summary > div {
    display: grid;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
  }

  .starter-library__summary strong {
    font-size: 2rem;
    line-height: 1;
  }

  .starter-library__summary span {
    color: rgb(92, 95, 98);
  }

  .starter-library__guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
  }

  .starter-library-guide-card {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 12px;
    background: linear-gradient(135deg, rgb(250, 251, 251), white);
  }

  .starter-library-guide-card > span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
    font-weight: 700;
  }

  .starter-library-guide-card h3,
  .starter-library-guide-card p {
    margin: 0;
  }

  .starter-library-guide-card p {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }

  .starter-library__group {
    display: grid;
    gap: 1.25rem;
    scroll-margin-top: 2rem;
  }

  .starter-library__heading {
    display: grid;
    gap: 0.35rem;
  }

  .starter-library__heading h2 {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
  }

  .starter-library__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    min-width: 0;
  }

  .starter-library__grid--small {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .starter-library-card {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background: white;
  }

  .starter-library-card--featured {
    border-color: rgb(32, 34, 35);
    background: rgb(250, 251, 251);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08);
  }

  .starter-library-card h3,
  .starter-library-card p {
    margin: 0;
  }

  .starter-library-card h3 {
    font-size: 1.1rem;
  }

  .starter-library-card p {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }

  .starter-library-modal-trigger {
    display: grid;
    gap: 0.15rem;
    width: fit-content;
    padding: 0.75rem 1rem;
    border: 1px solid rgb(32, 34, 35);
    border-radius: 999px;
    background: rgb(32, 34, 35);
    color: white;
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  .starter-library-modal-trigger small {
    opacity: 0.72;
    font-size: 0.75rem;
  }

  .starter-library__table {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
  }

  .starter-library__row {
    display: grid;
    grid-template-columns: minmax(140px, 0.6fr) minmax(220px, 0.9fr) minmax(240px, 1.5fr);
  }

  .starter-library__row > * {
    min-width: 0;
    padding: 0.85rem;
    border-top: 1px solid rgb(220, 220, 220);
  }

  .starter-library__row > * + * {
    border-left: 1px solid rgb(220, 220, 220);
  }

  .starter-library__row--head {
    background: rgb(246, 246, 247);
    font-weight: 700;
  }

  .starter-library__row--head > * {
    border-top: 0;
  }

  @media screen and (max-width: 749px) {
    .starter-library__table {
      overflow-x: auto;
    }

    .starter-library__row {
      min-width: 760px;
    }
  }
{% endstylesheet %}

