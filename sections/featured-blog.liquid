{% assign featured_blog = section.settings.blog %}

<section class="featured-blog">
  {% render 'section-header',
    eyebrow: section.settings.eyebrow,
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  {% if featured_blog != blank and featured_blog.articles_count > 0 %}
    <div class="featured-blog__grid">
      {% for article in featured_blog.articles limit: section.settings.article_limit %}
        {% render 'article-card',
          article: article,
          show_image: section.settings.show_image,
          show_excerpt: section.settings.show_excerpt,
          show_author: section.settings.show_author,
          show_date: section.settings.show_date,
          show_tags: section.settings.show_tags
        %}
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="featured-blog__footer">
        {% render 'main-button',
          label: section.settings.button_label,
          url: featured_blog.url,
          variant: section.settings.button_variant
        %}
      </div>
    {% endif %}
  {% elsif request.design_mode %}
    <p class="featured-blog__empty">{{ 'sections.featured_blog.empty' | t }}</p>
  {% endif %}
</section>

{% stylesheet %}
  .featured-blog {
    padding-block: 3rem;
  }

  .featured-blog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .featured-blog__footer {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .featured-blog__footer .main-button {
    margin-top: 0;
  }

  .featured-blog__empty {
    padding: 1rem;
    border: 1px dashed rgb(180, 180, 180);
    border-radius: 6px;
    color: rgb(92, 95, 98);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_blog",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Latest articles"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:labels.blog"
    },
    {
      "type": "range",
      "id": "article_limit",
      "label": "t:labels.article_limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:labels.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:labels.show_excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:labels.show_author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:labels.show_date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "t:labels.show_tags",
      "default": false
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "View all articles"
    },
    {
      "type": "select",
      "id": "button_variant",
      "label": "t:labels.button_variant",
      "options": [
        { "value": "primary", "label": "t:general.primary" },
        { "value": "secondary", "label": "t:general.secondary" },
        { "value": "accent", "label": "t:general.accent" }
      ],
      "default": "secondary"
    }
  ],
  "presets": [{ "name": "t:general.featured_blog" }]
}
{% endschema %}
