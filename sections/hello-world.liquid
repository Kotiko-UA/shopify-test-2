{% comment %}
  Welcome to Shopify theme development!
{% endcomment %}

<div
  class="section full-width"
  style="--section-spacing: {{ section.settings.section_spacing }}px; --background-color: {{ section.settings.background_color }};"
>
  <div class="container">
    <div class="welcome-content welcome-content--image-{{ section.settings.image_position }}">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <div class="welcome-eyebrow">
            {{ section.settings.eyebrow }}
          </div>
        {%- endif -%}
        <h1>{{ section.settings.heading }}</h1>
        {%- if section.settings.description != blank -%}
          <p class="welcome-description">
            {{ section.settings.description }}
          </p>
        {%- endif -%}
        {%- if section.settings.secondary_description != blank -%}
          <p class="welcome-description">
            {{ section.settings.secondary_description }}
          </p>
        {%- endif -%}
        {%- if section.settings.rich_description != blank -%}
          <div class="welcome-rich-description">
            {{ section.settings.rich_description }}
          </div>
        {%- endif -%}
        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          {%- render 'main-button',
            label: section.settings.button_label,
            url: section.settings.button_link,
            variant: section.settings.button_variant
          -%}
        {%- endif -%}
      </div>
      {%- if section.settings.image != blank -%}
        <div class="icon">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              widths: '300,600,900,1200',
              sizes: '(min-width: 990px) 300px, 80vw',
              loading: 'eager',
              alt: section.settings.heading,
              fetchpriority: 'high'
          }}
        </div>
      {%- endif -%}
    </div>
    {%- if section.settings.show_highlights -%}
      <div class="highlights">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'highlight' -%}
              <div class="highlight" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h3>{{ block.settings.title }}</h3>
                {%- endif -%}

                {%- if block.settings.description != blank -%}
                  <p class="highlight-description">
                    {{ block.settings.description }}
                  </p>
                {%- endif -%}

                {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
                  <p>
                    {{ block.settings.link_label | link_to: block.settings.link_url }}
                  </p>
                {%- endif -%}
              </div>

            {%- when 'quote' -%}
              <blockquote class="highlight highlight-quote" {{ block.shopify_attributes }}>
                {%- if block.settings.text != blank -%}
                  <p class="highlight-quote-text">
                    {{ block.settings.text }}
                  </p>
                {%- endif -%}

                {%- if block.settings.author != blank -%}
                  <cite class="highlight-quote-author">
                    {{ block.settings.author }}
                  </cite>
                {%- endif -%}
              </blockquote>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.featured_collection != blank -%}
      <div class="welcome-collection">
        <span>{{ 'hello_world.featured_collection' | t }}</span>
        <a href="{{ section.settings.featured_collection.url }}">
          {{ section.settings.featured_collection.title }}
        </a>
        <div class="welcome-collection-products">
          {%- for product in section.settings.featured_collection.products limit: 3 -%}
            {% render 'product-card', product: product, show_vendor: false %}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
    {%- if section.settings.featured_product != blank -%}
      <div class="welcome-product">
        <span>{{ 'hello_world.featured_product' | t }}</span>
        <a href="{{ section.settings.featured_product.url }}">
          {{ section.settings.featured_product.title }}
        </a>
        <span>{{ section.settings.featured_product.price | money }}</span>
      </div>
    {%- endif -%}
    {%- if section.settings.featured_page != blank -%}
      <div class="welcome-page">
        <span>{{ 'hello_world.featured_page' | t }}</span>
        <a href="{{ section.settings.featured_page.url }}">
          {{ section.settings.featured_page.title }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .section {
    display: block;
    background-color: var(--background-color);
    padding: var(--section-spacing) 0;
  }
  .container {
    width: 100%;
    padding: 0 16px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .welcome-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 0 24px;
  }
  .welcome-eyebrow {
    margin-bottom: 0.75rem;
    color: rgb(92, 95, 98);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .welcome-content--image-left {
    flex-direction: row-reverse;
  }

  .welcome-description {
    max-width: 80ch;
    line-height: 1.4;
    margin-top: 1.5rem;
  }

  .welcome-rich-description {
    max-width: 80ch;
    line-height: 1.4;
    margin-top: 1.5rem;
  }

  .icon {
    width: 300px;
  }

  .highlights {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(3, 1fr);
    margin-top: 50px;
  }

  @media (max-width: 1100px) {
    .highlights {
      grid-template-columns: 1fr;
    }
  }

  .highlight {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 24px;
    border-radius: 8px;
    background-color: #eef3ff;
    color: rgb(92, 95, 98);
    line-height: 1.4;
  }

  .highlight > * + * {
    margin-top: 1rem;
  }

  .highlight h3 {
    font-size: 1rem;
    color: rgb(32, 34, 35);
  }

  .highlight-description {
    flex: 1 1;
  }

  .highlight a {
    display: flex;
    width: fit-content;
    background-color: rgb(250, 251, 251);
    box-shadow: rgba(0, 0, 0, 0.2) 0px -3px 0px 0px inset, rgba(255, 255, 255, 0.9) 0px 2px 0px 0px inset;
    border: 1px solid rgb(140, 145, 150);
    border-radius: 4px;
    color: rgb(92, 95, 98);
    padding: 3px 10px 5px;
    text-decoration: none;
  }
  .highlight-quote {
    border-left: 4px solid rgb(32, 34, 35);
  }

  .highlight-quote-text {
    flex: 1 1;
    font-style: italic;
  }

  .highlight-quote-author {
    color: rgb(32, 34, 35);
    font-style: normal;
    font-weight: 700;
  }
  .welcome-collection {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.5rem;
    line-height: 1.4;
  }
  .welcome-collection span {
    color: rgb(92, 95, 98);
  }

  .welcome-collection-products {
    margin: 0.5rem 0 0;
    display: flex;
    gap: 0.5rem;
  }

  .welcome-product {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.5rem;
    line-height: 1.4;
  }

  .welcome-product span {
    color: rgb(92, 95, 98);
  }
  .welcome-page {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.5rem;
    line-height: 1.4;
  }

  .welcome-page span {
    color: rgb(92, 95, 98);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hello World",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Built with Shopify"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My first Shopify section"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "This is cool text of description"
    },
    {
      "type": "textarea",
      "id": "secondary_description",
      "label": "Second Description",
      "default": "Themes shape the online store experience for merchants and their customers. Build fast, flexible themes at scale using Liquid, Shopify's theme templating language, along with HTML, CSS, JavaScript, and JSON."
    },
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    { "type": "checkbox", "id": "show_highlights", "label": "Show highlight blocks", "default": true },
    {
      "type": "range",
      "id": "section_spacing",
      "label": "Section vertical spacing",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f6f6f7"
    },
    {
      "type": "richtext",
      "id": "rich_description",
      "label": "Rich description",
      "default": "<p>Add formatted text for this section.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "button_variant",
      "label": "Button style",
      "options": [
        {
          "value": "primary",
          "label": "Primary"
        },
        {
          "value": "secondary",
          "label": "Secondary"
        }
      ],
      "default": "primary"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "t:labels.featured_collection"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    },
    {
      "type": "page",
      "id": "featured_page",
      "label": "Featured page"
    }
  ],
  "max_blocks": 4,
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Key Concepts"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this highlight card."
        },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Learn More" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    },
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "This is a quote from a happy customer."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Customer name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hello World Template",
      "category": "Demo",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "title": "Key Concepts",
            "description": "Shopify themes are made from templates, sections, blocks, and assets.",
            "link_label": "Learn more"
          }
        },
        {
          "type": "highlight",
          "settings": {
            "title": "Liquid",
            "description": "Liquid is Shopify's templating language for rendering dynamic storefront content.",
            "link_label": "View reference"
          }
        },
        {
          "type": "quote",
          "settings": {
            "text": "This section is now powered by reusable blocks.",
            "author": "Theme developer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
