<script src="{{ 'faq.js' | asset_url }}" defer></script>

<section
  class="faq-section"
  data-faq-section
  data-animation-duration="{{ section.settings.animation_duration }}"
>
  {% render 'section-header',
    eyebrow: section.settings.eyebrow,
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  <div class="faq-section__items">
    {% for block in section.blocks %}
      <details class="faq-section__item" data-faq-item {{ block.shopify_attributes }}>
        <summary data-faq-summary>
          <span>{{ block.settings.question | escape }}</span>
          <span class="faq-section__chevron" aria-hidden="true"></span>
        </summary>
        <div class="faq-section__content" data-faq-content>
          <div class="faq-section__answer">
            {{ block.settings.answer }}
          </div>
        </div>
      </details>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .faq-section {
    padding-block: 3rem;
  }

  .faq-section__items {
    display: grid;
    gap: 0.75rem;
  }

  .faq-section__item {
    border: 1px solid color-mix(in srgb, var(--color-foreground), transparent 78%);
    border-radius: 6px;
    background-color: var(--color-background);
  }

  .faq-section__item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    cursor: pointer;
    padding: 1rem;
    font-weight: 700;
    list-style: none;
  }

  .faq-section__item summary::-webkit-details-marker {
    display: none;
  }

  .faq-section__item summary::marker {
    content: '';
  }

  .faq-section__item summary:focus-visible {
    border-radius: 5px;
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .faq-section__chevron {
    flex: 0 0 auto;
    width: 0.65rem;
    height: 0.65rem;
    margin-right: 0.2rem;
    border-right: 2px solid currentColor;
    border-bottom: 2px solid currentColor;
    transform: rotate(45deg);
    transition: transform 350ms ease;
  }

  .faq-section__item[open]:not([data-faq-closing='true']) .faq-section__chevron {
    transform: rotate(225deg);
  }

  .faq-section__content {
    overflow: hidden;
  }

  .faq-section__answer {
    padding: 0 1rem 1rem;
    color: color-mix(in srgb, var(--color-foreground), transparent 25%);
    line-height: 1.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-section__chevron {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.faq",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Questions and answers"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "t:labels.animation_speed",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "ms",
      "default": 450
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "t:general.question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:labels.question",
          "default": "What should customers know?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:labels.answer",
          "default": "<p>Add a clear answer for shipping, returns, product care, sizing, or promotions.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.faq",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
