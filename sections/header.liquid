<script src="{{ 'header.js' | asset_url }}" defer></script>

<header
  class="site-header site-header--menu-{{ section.settings.menu_position }}{% if section.settings.sticky_header %} site-header--sticky{% endif %}{% if section.settings.transparent_header %} site-header--transparent{% endif %}"
  data-site-header
  style="
    --header-background: {{ section.settings.background_color }};
    --header-foreground: {{ section.settings.text_color }};
    --header-logo-width: {{ section.settings.logo_width }}px;
  "
>
  <div class="site-header__inner">
    <details class="site-header__mobile-menu" data-header-mobile-menu>
      <summary class="site-header__icon-button site-header__mobile-trigger">
        <span aria-hidden="true">{{ 'navigation.menu' | t }}</span>
      </summary>
      <button class="site-header__overlay" type="button" data-header-close aria-label="{{ 'accessibility.close' | t }}"></button>
      <div class="site-header__mobile-panel">
        <div class="site-header__panel-header">
          <strong>{{ 'navigation.menu' | t }}</strong>
          <button type="button" data-header-close aria-label="{{ 'accessibility.close' | t }}">&times;</button>
        </div>
        <nav aria-label="{{ 'navigation.menu' | t }}">
          {% for link in section.settings.menu.links %}
            <div class="site-header__mobile-item">
              {% if link.links != blank %}
                <details>
                  <summary class="site-header__mobile-link{% if link.active or link.child_active %} is-active{% endif %}">
                    {{ link.title }}
                  </summary>
                  <div class="site-header__mobile-submenu">
                    {% for child_link in link.links %}
                      <a class="{% if child_link.active %}is-active{% endif %}" href="{{ child_link.url }}">
                        {{ child_link.title }}
                      </a>
                      {% if child_link.links != blank %}
                        <div class="site-header__mobile-grandchildren">
                          {% for grandchild_link in child_link.links %}
                            <a href="{{ grandchild_link.url }}">{{ grandchild_link.title }}</a>
                          {% endfor %}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </details>
              {% else %}
                <a class="site-header__mobile-link{% if link.active %} is-active{% endif %}" href="{{ link.url }}">
                  {{ link.title }}
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </nav>
      </div>
    </details>

    <a class="site-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      {% if section.settings.logo != blank %}
        {% assign rendered_logo_width = section.settings.logo_width | times: 2 %}
        {{
          section.settings.logo
          | image_url: width: rendered_logo_width
          | image_tag: widths: '120, 180, 240, 320, 400', loading: 'eager', alt: shop.name
        }}
      {% else %}
        <span>{{ shop.name | escape }}</span>
      {% endif %}
    </a>

    <nav class="site-header__menu" aria-label="{{ 'navigation.menu' | t }}">
      {% for link in section.settings.menu.links %}
        {% assign mega_menu_block = nil %}
        {% assign normalized_link_title = link.title | strip | downcase %}
        {% for block in section.blocks %}
          {% assign normalized_block_title = block.settings.menu_item | strip | downcase %}
          {% if normalized_block_title == normalized_link_title %}
            {% assign mega_menu_block = block %}
            {% break %}
          {% endif %}
        {% endfor %}

        <div class="site-header__menu-item">
          <a class="site-header__menu-link{% if link.active or link.child_active %} is-active{% endif %}" href="{{ link.url }}">
            {{ link.title }}
          </a>

          {% if link.links != blank %}
            <div class="site-header__submenu{% if mega_menu_block %} site-header__submenu--mega{% endif %}">
              <div class="site-header__submenu-links">
                {% for child_link in link.links %}
                  <div>
                    <a class="site-header__submenu-link{% if child_link.active %} is-active{% endif %}" href="{{ child_link.url }}">
                      {{ child_link.title }}
                    </a>
                    {% if child_link.links != blank %}
                      <div class="site-header__grandchildren">
                        {% for grandchild_link in child_link.links %}
                          <a href="{{ grandchild_link.url }}">{{ grandchild_link.title }}</a>
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>

              {% if mega_menu_block %}
                <a class="site-header__promo" href="{{ mega_menu_block.settings.link }}" {{ mega_menu_block.shopify_attributes }}>
                  {% if mega_menu_block.settings.image != blank %}
                    {{
                      mega_menu_block.settings.image
                      | image_url: width: 480
                      | image_tag: widths: '240, 360, 480', loading: 'lazy', alt: mega_menu_block.settings.heading
                    }}
                  {% endif %}
                  {% if mega_menu_block.settings.heading != blank %}<strong>{{ mega_menu_block.settings.heading | escape }}</strong>{% endif %}
                  {% if mega_menu_block.settings.text != blank %}<span>{{ mega_menu_block.settings.text | escape }}</span>{% endif %}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </nav>

    <div class="site-header__icons">
      {% if section.settings.show_search %}
        <details class="site-header__search" data-header-search>
          <summary class="site-header__icon-button">{{ 'search.submit' | t }}</summary>
          <div class="site-header__search-panel">
            <div class="site-header__search-inner">
              <form action="{{ routes.search_url }}" method="get" role="search">
                <label for="HeaderSearch-{{ section.id }}">{{ 'search.title' | t }}</label>
                <div>
                  <input id="HeaderSearch-{{ section.id }}" type="search" name="q" placeholder="{{ 'search.placeholder' | t | escape }}" autocomplete="off">
                  <button type="submit">{{ 'search.submit' | t }}</button>
                </div>
              </form>
              <button type="button" data-header-close aria-label="{{ 'accessibility.close' | t }}">&times;</button>
            </div>
          </div>
        </details>
      {% endif %}

      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}" aria-label="{{ 'accessibility.account' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a class="site-header__cart-link" href="{{ routes.cart_url }}" aria-label="{{ 'accessibility.cart' | t: count: cart.item_count }}" aria-controls="CartDrawer" aria-expanded="false" data-cart-label-template="{{ 'accessibility.cart' | t: count: 'COUNT' | escape }}" data-cart-drawer-trigger>
        <sup class="site-header__cart-count" {% if cart.item_count == 0 %}hidden{% endif %}>{{ cart.item_count }}</sup>
        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header { position: relative; z-index: 20; color: var(--header-foreground); background: var(--header-background); transition: background-color 180ms ease, box-shadow 180ms ease; }
  .site-header--sticky { position: sticky; top: 0; }
  .site-header--transparent:not(.site-header--scrolled) { background: transparent; }
  .site-header--scrolled { background: var(--header-background); box-shadow: 0 1px 12px rgba(0, 0, 0, 0.1); }
  .site-header__inner { display: grid; grid-template-columns: auto minmax(0, 1fr) auto; gap: 2rem; align-items: center; min-height: 5rem; }
  .site-header__logo { display: block; width: min(var(--header-logo-width), 100%); color: inherit; font-weight: 700; text-decoration: none; }
  .site-header__logo img { display: block; width: 100%; height: auto; }
  .site-header__menu, .site-header__icons { display: flex; gap: 1rem; align-items: center; }
  .site-header--menu-center .site-header__menu { justify-content: center; }
  .site-header--menu-right .site-header__menu { justify-content: flex-end; }
  .site-header a, .site-header summary { color: inherit; }
  .site-header__menu-item { position: relative; }
  .site-header__menu-link, .site-header__submenu a, .site-header__mobile-panel a { text-decoration: none; }
  .site-header .is-active { font-weight: 700; text-decoration: underline; }
  .site-header__submenu { position: absolute; top: 100%; left: 0; display: none; min-width: 220px; padding: 1rem; border: 1px solid rgb(220, 220, 220); border-radius: 6px; background: var(--header-background); box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12); }
  .site-header__menu-item:hover .site-header__submenu, .site-header__menu-item:focus-within .site-header__submenu { display: grid; }
  .site-header__submenu--mega { grid-template-columns: minmax(300px, 1fr) 240px; width: min(720px, 82vw); }
  .site-header__submenu-links { display: grid; grid-template-columns: repeat(3, minmax(130px, 1fr)); gap: 1rem; }
  .site-header__grandchildren, .site-header__mobile-grandchildren { display: grid; gap: 0.35rem; margin-top: 0.5rem; font-size: 0.9rem; opacity: 0.8; }
  .site-header__promo { display: grid; gap: 0.35rem; }
  .site-header__promo img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 4px; }
  .site-header__icons { justify-content: flex-end; }
  .site-header__icons svg { width: 1.75rem; }
  .site-header__icon-button { cursor: pointer; list-style: none; }
  .site-header__cart-link { position: relative; display: flex; }
  .site-header__cart-count { position: absolute; top: -0.6rem; right: -0.7rem; min-width: 1.2rem; padding: 0.1rem; border-radius: 999px; background: var(--header-foreground); color: var(--header-background); font-size: 0.7rem; text-align: center; }
  .site-header__search-panel { position: fixed; z-index: 30; top: 0; right: 0; left: 0; padding: 1.5rem; background: var(--header-background); box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18); }
  .site-header__search-inner { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 1rem; align-items: end; width: min(760px, 100%); margin-inline: auto; }
  .site-header__search form, .site-header__search form > div { display: grid; gap: 0.5rem; }
  .site-header__search form > div { grid-template-columns: minmax(0, 1fr) auto; }
  .site-header__search input, .site-header__search button { min-height: 44px; padding: 0.65rem 0.85rem; }
  .site-header__mobile-menu { display: none; }
  .site-header__overlay { position: fixed; z-index: 25; inset: 0; border: 0; background: rgba(0, 0, 0, 0.45); }
  .site-header__mobile-panel { position: fixed; z-index: 26; top: 0; bottom: 0; left: 0; width: min(88vw, 380px); overflow-y: auto; padding: 1.25rem; background: var(--header-background); box-shadow: 12px 0 36px rgba(0, 0, 0, 0.18); }
  .site-header__panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .site-header__panel-header button { border: 0; background: transparent; font-size: 2rem; }
  .site-header__mobile-item { border-bottom: 1px solid color-mix(in srgb, currentcolor, transparent 82%); }
  .site-header__mobile-link, .site-header__mobile-submenu a { display: block; padding: 0.8rem 0; }
  .site-header__mobile-submenu { padding: 0 0 0.75rem 1rem; }
  @media screen and (max-width: 749px) {
    .site-header__inner { grid-template-columns: auto minmax(0, 1fr) auto; gap: 1rem; }
    .site-header__menu { display: none; }
    .site-header__mobile-menu { display: block; }
    .site-header__logo { justify-self: center; }
    .site-header__icons { gap: 0.65rem; }
  }
  @media (prefers-reduced-motion: reduce) { .site-header { transition: none; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "t:labels.logo" },
    { "type": "range", "id": "logo_width", "label": "t:labels.logo_width", "min": 80, "max": 240, "step": 10, "unit": "px", "default": 140 },
    { "type": "link_list", "id": "menu", "label": "t:labels.menu" },
    { "type": "link_list", "id": "customer_account_menu", "label": "t:labels.customer_account_menu", "default": "customer-account-main-menu" },
    {
      "type": "select",
      "id": "menu_position",
      "label": "t:labels.menu_position",
      "default": "center",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ]
    },
    { "type": "checkbox", "id": "show_search", "label": "t:labels.show_search", "default": true },
    { "type": "checkbox", "id": "sticky_header", "label": "t:labels.sticky_header", "default": true },
    { "type": "checkbox", "id": "transparent_header", "label": "t:labels.transparent_header", "default": false },
    { "type": "color", "id": "background_color", "label": "t:labels.background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "t:labels.text_color", "default": "#202223" }
  ],
  "blocks": [
    {
      "type": "mega_menu",
      "name": "t:general.mega_menu",
      "settings": [
        { "type": "text", "id": "menu_item", "label": "t:labels.menu_item", "info": "Use the exact title of a top-level menu item." },
        { "type": "image_picker", "id": "image", "label": "t:labels.image" },
        { "type": "text", "id": "heading", "label": "t:labels.heading" },
        { "type": "text", "id": "text", "label": "t:labels.text" },
        { "type": "url", "id": "link", "label": "t:labels.link" }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
