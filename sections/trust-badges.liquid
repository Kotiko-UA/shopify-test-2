<section class="trust-badges">
  {% render 'section-header',
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  <div class="trust-badges__grid">
    {% for block in section.blocks %}
      <article class="trust-badge" {{ block.shopify_attributes }}>
        {% if block.settings.icon != blank %}
          {% render 'image',
            class: 'trust-badge__icon',
            image: block.settings.icon,
            alt: block.settings.heading,
            width: 96,
            widths: '48, 72, 96',
            sizes: '48px'
          %}
        {% endif %}

        {% if block.settings.heading != blank %}
          <h3>{{ block.settings.heading | escape }}</h3>
        {% endif %}

        {% if block.settings.text != blank %}
          <div class="trust-badge__text">
            {{ block.settings.text }}
          </div>
        {% endif %}
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .trust-badges {
    padding-block: 2.5rem;
  }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .trust-badge {
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: white;
  }

  .trust-badge__icon {
    width: 48px;
  }

  .trust-badge__icon img {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .trust-badge h3 {
    margin: 0;
    font-size: 1rem;
  }

  .trust-badge__text {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.trust_badges",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "t:general.badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:labels.icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Free shipping"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:labels.text",
          "default": "<p>Add a short trust-building benefit.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.trust_badges",
      "blocks": [
        { "type": "badge" },
        { "type": "badge" },
        { "type": "badge" }
      ]
    }
  ]
}
{% endschema %}
