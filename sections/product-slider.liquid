<section class="product-slider">
  {% render 'section-header',
    eyebrow: section.settings.eyebrow,
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  {% if section.blocks.size > 0 %}
    <div class="product-slider__track" aria-label="{{ section.settings.heading | escape }}">
      {% for block in section.blocks %}
        {% if block.settings.product != blank %}
          <div class="product-slider__item" {{ block.shopify_attributes }}>
            {% render 'product-card', product: block.settings.product, show_vendor: section.settings.show_vendor %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% elsif request.design_mode %}
    <p class="product-slider__empty">{{ 'sections.product_slider.empty' | t }}</p>
  {% endif %}
</section>

{% stylesheet %}
  .product-slider {
    padding-block: 3rem;
  }

  .product-slider__track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 0.5rem;
  }

  .product-slider__item {
    flex: 0 0 min(300px, 82vw);
    scroll-snap-align: start;
  }

  .product-slider__empty {
    padding: 1rem;
    border: 1px dashed rgb(180, 180, 180);
    border-radius: 6px;
    color: rgb(92, 95, 98);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product_slider",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Selected products"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "t:general.product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "t:labels.product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.product_slider",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
