{% comment %}
  This section is used in the article template to render a single blog article.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/article
{% endcomment %}

{% assign related_article_limit = section.settings.related_article_limit | default: 3 %}
{% assign comment_success_text = 'blog.comment_form_success' | t %}

<article class="article-page">
  <header class="article-page__header">
    <a class="article-page__back" href="{{ blog.url }}">{{ 'blog.back_to_blog' | t: blog: blog.title }}</a>

    <h1>{{ article.title | escape }}</h1>

    {% if section.settings.show_author or section.settings.show_date %}
      {% assign date = article.published_at | time_tag: format: 'date' %}
      <p class="article-page__meta">
        {% if section.settings.show_author and section.settings.show_date %}
          {{ 'blog.article_metadata_html' | t: date: date, author: article.author }}
        {% elsif section.settings.show_date %}
          {{ date }}
        {% elsif section.settings.show_author %}
          {{ article.author }}
        {% endif %}
      </p>
    {% endif %}

    {% if section.settings.show_tags and article.tags.size > 0 %}
      <ul class="article-page__tags">
        {% for tag in article.tags %}
          <li>{{ tag | link_to_tag: tag }}</li>
        {% endfor %}
      </ul>
    {% endif %}
  </header>

  {% if section.settings.show_image and article.image %}
    {% assign article_image_alt = article.image.alt | default: article.title %}
    <div class="article-page__media">
      {{
        article.image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          alt: article_image_alt,
          widths: '600, 900, 1200, 1600',
          sizes: '(min-width: 900px) 860px, calc(100vw - 2rem)'
      }}
    </div>
  {% endif %}

  <div class="article-page__content">
    {{ article.content }}
  </div>

  {% if section.settings.show_share_links %}
    <div class="article-page__share" aria-label="{{ 'blog.share_article' | t }}">
      <span>{{ 'blog.share_article' | t }}</span>
      <a
        href="https://www.facebook.com/sharer/sharer.php?u={{ canonical_url | url_encode }}"
        target="_blank"
        rel="noopener noreferrer"
      >
        {{ 'blog.share_on_facebook' | t }}
      </a>
      <a
        href="https://twitter.com/intent/tweet?url={{ canonical_url | url_encode }}&amp;text={{ article.title | url_encode }}"
        target="_blank"
        rel="noopener noreferrer"
      >
        {{ 'blog.share_on_x' | t }}
      </a>
      <a href="mailto:?subject={{ article.title | url_encode }}&amp;body={{ canonical_url | url_encode }}">
        {{ 'blog.share_by_email' | t }}
      </a>
    </div>
  {% endif %}
</article>

{% if section.settings.show_related_articles and blog.articles_count > 1 %}
  <aside class="article-related" aria-labelledby="ArticleRelatedHeading-{{ section.id }}">
    <h2 id="ArticleRelatedHeading-{{ section.id }}">{{ 'blog.more_articles' | t }}</h2>

    <div class="article-related__grid">
      {% assign related_articles_shown = 0 %}
      {% for related_article in blog.articles %}
        {% if related_article.id != article.id and related_articles_shown < related_article_limit %}
          {% render 'article-card',
            article: related_article,
            show_image: section.settings.show_image,
            show_excerpt: true,
            show_author: section.settings.show_author,
            show_date: section.settings.show_date,
            show_tags: section.settings.show_tags,
            excerpt_length: 120
          %}
          {% assign related_articles_shown = related_articles_shown | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  </aside>
{% endif %}

{% if blog.comments_enabled? and section.settings.show_comments %}
  <section class="article-comments" id="comments">
    <h2>{{ 'blog.article_comments' | t }}</h2>

    {% paginate article.comments by section.settings.comments_per_page %}
      {% if article.comments_count > 0 %}
        <div class="article-comments__list">
          {% for comment in article.comments %}
            <article class="article-comment">
              <div class="article-comment__header">
                <p class="article-comment__author">{{ comment.author }}</p>
                <p class="article-comment__date">{{ comment.created_at | time_tag: format: 'date' }}</p>
              </div>
              <div class="article-comment__content">
                {{ comment.content }}
              </div>
            </article>
          {% endfor %}
        </div>

        {% render 'pagination', paginate: paginate, class: 'article-comments__pagination', anchor: 'comments' %}
      {% else %}
        <p class="article-comments__empty">{{ 'blog.comments_empty' | t }}</p>
      {% endif %}
    {% endpaginate %}

    {% form 'new_comment', article, class: 'article-comment-form' %}
      <h2>{{ 'blog.comment_form_title' | t }}</h2>

      {% render 'form-message',
        form: form,
        success_text: comment_success_text,
        success_class: 'article-comment-form__success',
        errors_class: 'article-comment-form__errors'
      %}

      <div class="article-comment-form__field">
        <label for="CommentAuthor-{{ section.id }}">{{ 'blog.comment_form_name' | t }}</label>
        <input
          id="CommentAuthor-{{ section.id }}"
          type="text"
          name="comment[author]"
          value="{{ form.author }}"
          autocomplete="name"
          required
        >
      </div>

      <div class="article-comment-form__field">
        <label for="CommentEmail-{{ section.id }}">{{ 'blog.comment_form_email' | t }}</label>
        <input
          id="CommentEmail-{{ section.id }}"
          type="email"
          name="comment[email]"
          value="{{ form.email }}"
          autocomplete="email"
          required
        >
      </div>

      <div class="article-comment-form__field">
        <label for="CommentBody-{{ section.id }}">{{ 'blog.comment_form_body' | t }}</label>
        <textarea id="CommentBody-{{ section.id }}" name="comment[body]" rows="6" required>{{ form.body }}</textarea>
      </div>

      <button type="submit">{{ 'blog.comment_form_submit' | t }}</button>
    {% endform %}
  </section>
{% endif %}

{% stylesheet %}
  .article-page,
  .article-comments {
    width: min(100% - 2rem, 860px);
    margin-inline: auto;
  }

  .article-related {
    width: min(100% - 2rem, 1200px);
    margin-inline: auto;
    padding-bottom: 2rem;
  }

  .article-page {
    padding-block: 2rem;
  }

  .article-page__header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .article-page__back {
    justify-self: start;
    color: rgb(92, 95, 98);
  }

  .article-page__meta {
    color: rgb(92, 95, 98);
  }

  .article-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-page__tags a {
    display: inline-flex;
    padding: 0.25rem 0.5rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 4px;
    color: inherit;
    font-size: 0.75rem;
    text-decoration: none;
  }

  .article-page__media {
    margin-bottom: 1.5rem;
  }

  .article-page__media img {
    width: 100%;
    border-radius: 8px;
  }

  .article-page__content {
    display: grid;
    gap: 1rem;
    line-height: 1.7;
  }

  .article-page__content > * {
    margin-block: 0;
  }

  .article-page__content h2,
  .article-page__content h3,
  .article-page__content h4 {
    margin-top: 1rem;
    line-height: 1.25;
  }

  .article-page__content a {
    color: inherit;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .article-page__content ul,
  .article-page__content ol {
    padding-left: 1.4rem;
  }

  .article-page__content blockquote {
    margin: 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid rgb(32, 34, 35);
    border-radius: 0 8px 8px 0;
    background: rgb(246, 246, 247);
  }

  .article-page__content img,
  .article-page__content video,
  .article-page__content iframe {
    max-width: 100%;
    border-radius: 8px;
  }

  .article-page__content img,
  .article-page__content video {
    height: auto;
  }

  .article-page__content iframe {
    width: 100%;
    border: 0;
  }

  .article-page__content table {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
  }

  .article-page__content th,
  .article-page__content td {
    padding: 0.6rem 0.75rem;
    border: 1px solid rgb(220, 220, 220);
    text-align: left;
  }

  .article-page__share {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    align-items: center;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgb(220, 220, 220);
  }

  .article-page__share span {
    font-weight: 700;
  }

  .article-page__share a {
    color: inherit;
  }

  .article-related {
    display: grid;
    gap: 1rem;
  }

  .article-related__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .article-comments {
    display: grid;
    gap: 1.5rem;
    padding-bottom: 2rem;
  }

  .article-comments__list {
    display: grid;
    gap: 1rem;
  }

  .article-comment {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background: white;
  }

  .article-comment__header {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    justify-content: space-between;
  }

  .article-comment__author {
    font-weight: 700;
  }

  .article-comment__date,
  .article-comments__empty {
    color: rgb(92, 95, 98);
  }

  .article-comment-form {
    display: grid;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
  }

  .article-comment-form__field {
    display: grid;
    gap: 0.35rem;
  }

  .article-comment-form input,
  .article-comment-form textarea {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .article-comment-form button {
    justify-self: start;
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .article-comment-form__success {
    color: rgb(0, 128, 96);
  }

  @media screen and (min-width: 750px) {
    .article-related__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.article",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:labels.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:labels.show_author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:labels.show_date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "t:labels.show_tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_share_links",
      "label": "t:labels.show_share_links",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related_articles",
      "label": "t:labels.show_related_articles",
      "default": true
    },
    {
      "type": "range",
      "id": "related_article_limit",
      "label": "t:labels.related_article_limit",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_comments",
      "label": "t:labels.show_comments",
      "default": true
    },
    {
      "type": "range",
      "id": "comments_per_page",
      "label": "t:labels.comments_per_page",
      "min": 5,
      "max": 20,
      "step": 5,
      "default": 10
    }
  ]
}
{% endschema %}
