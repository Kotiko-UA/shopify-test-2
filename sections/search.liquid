{% comment %}
  This section is used in the search template to render search results for
  products, articles, and pages.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

{{ 'predictive-search.css' | asset_url | stylesheet_tag }}
<script src="{{ 'predictive-search.js' | asset_url }}" defer></script>

{% assign search_title_text = 'search.title' | t %}
{% assign search_placeholder_text = 'search.placeholder' | t %}
{% assign search_submit_text = 'search.submit' | t %}

<div class="search-page">
  <header class="search-page__header">
    <h1>{{ 'search.title' | t }}</h1>

    {% render 'predictive-search-form',
      input_id: 'SearchInput',
      panel_id: 'predictive-search',
      types: 'product,page,article',
      class: 'predictive-search',
      form_class: 'search-form',
      label: search_title_text,
      label_class: 'visually-hidden',
      input_class: 'search-form__input',
      input_value: search.terms,
      placeholder: search_placeholder_text,
      button_class: 'search-form__button',
      button_label: search_submit_text,
      unavailable_products: 'last'
    %}
  </header>

  {% if search.performed %}
    <div class="search-page__summary">
      {% if search.results_count == 0 %}
        <p>{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      {% else %}
        <p>{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>
      {% endif %}
    </div>

    {% if search.results_count > 0 %}
      {% paginate search.results by section.settings.results_per_page %}
        <div class="search-results">
          {% for result in search.results %}
            {% case result.object_type %}
              {% when 'product' %}
                {% render 'product-card',
                  product: result,
                  show_vendor: section.settings.show_vendor,
                  show_badges: section.settings.show_badges,
                  show_secondary_image: section.settings.show_secondary_image,
                  enable_quick_add: section.settings.enable_quick_add
                %}

              {% when 'article' %}
                {% render 'article-card',
                  article: result,
                  show_image: false,
                  show_excerpt: true,
                  show_author: false,
                  show_date: true,
                  show_tags: false
                %}

              {% when 'page' %}
                <article class="search-result-card">
                  <p class="search-result-card__type">{{ 'search.types.page' | t }}</p>
                  <h2 class="search-result-card__title">
                    <a href="{{ result.url }}">{{ result.title | escape }}</a>
                  </h2>
                  {% if result.content != blank %}
                    <p class="search-result-card__text">
                      {{ result.content | strip_html | truncate: 160 }}
                    </p>
                  {% endif %}
                </article>
            {% endcase %}
          {% endfor %}
        </div>

        {% render 'pagination', paginate: paginate, class: 'search-pagination' %}
      {% endpaginate %}
    {% endif %}
  {% endif %}
</div>

{% stylesheet %}
  .search-page {
    width: min(100% - 2rem, 1200px);
    margin-inline: auto;
    padding-block: 2rem;
  }

  .search-page__header {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .search-form {
    position: relative;
    display: flex;
    gap: 0.75rem;
    max-width: 720px;
  }

  .search-form__input {
    flex: 1;
    min-height: 44px;
    min-width: 0;
    padding: 0.65rem 0.8rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .search-form__button {
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .search-page__summary {
    margin-bottom: 1.5rem;
    color: rgb(92, 95, 98);
  }

  .search-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .search-result-card {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    min-height: 100%;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background: white;
  }

  .search-result-card__type {
    margin: 0;
    color: rgb(92, 95, 98);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .search-result-card__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  .search-result-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .search-result-card__text {
    margin: 0;
    color: rgb(92, 95, 98);
  }

  .search-pagination {
    margin-top: 2rem;
  }

  .search-pagination .pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  @media screen and (max-width: 749px) {
    .search-form {
      flex-direction: column;
    }

    .search-form__button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "t:labels.results_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "t:labels.show_badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:labels.show_secondary_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "t:labels.enable_quick_add",
      "default": true
    }
  ]
}
{% endschema %}
