{% comment %}
  This section is used in the collection template to render collection page
  listing all products within a collection.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<script src="{{ 'collection.js' | asset_url }}" defer></script>
{% assign collection_search_label = 'collections.search_products' | t %}
{% assign collection_search_placeholder = 'collections.search_placeholder' | t %}
{% assign search_submit_label = 'search.submit' | t %}

{% if section.settings.show_search != false %}
  {{ 'predictive-search.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
{% endif %}

<h1>{{ collection.title }}</h1>
{% if collection.description != blank %}
  <div class="collection-description">
    {{ collection.description }}
  </div>
{% endif %}
<div
  data-collection-content
  data-section-id="{{ section.id }}"
  style="--collection-columns-desktop: {{ section.settings.columns_desktop }}; --collection-columns-mobile: {{ section.settings.columns_mobile }};"
>
{% paginate collection.products by section.settings.products_per_page %}
  {% assign current_sort = collection.sort_by | default: collection.default_sort_by %}
  {% assign active_filter_count = 0 %}
  {% for filter in collection.filters %}
    {% if filter.type == 'price_range' %}
      {% if filter.min_value.value != blank or filter.max_value.value != blank %}
        {% assign active_filter_count = active_filter_count | plus: 1 %}
      {% endif %}
    {% else %}
      {% assign active_filter_count = active_filter_count | plus: filter.active_values.size %}
    {% endif %}
  {% endfor %}

  <div class="collection-toolbar{% if section.settings.sticky_toolbar %} collection-toolbar--sticky{% endif %}">
    <p class="collection-product-count">{{ 'collections.product_count' | t: count: paginate.items }}</p>

    {% if collection.filters.size > 0 %}
      <button class="collection-filter-toggle" type="button" data-collection-filter-toggle>
        {{ 'collections.filters' | t }}{% if active_filter_count > 0 %} ({{ active_filter_count }}){% endif %}
      </button>
    {% endif %}

    {% if section.settings.show_search != false %}
      {% render 'predictive-search-form',
        input_id: 'CollectionProductSearch',
        panel_id: 'collection-predictive-search',
        types: 'product',
        class: 'collection-predictive-search',
        form_class: 'collection-search-form',
        row_class: 'collection-search-form__row',
        label: collection_search_label,
        placeholder: collection_search_placeholder,
        button_label: search_submit_label,
        unavailable_products: 'last'
      %}
    {% endif %}

    <form class="collection-sort-form" method="get">
      {% for filter in collection.filters %}
        {% if filter.type == 'price_range' %}
          {% if filter.min_value.value != blank %}
            <input
              type="hidden"
              name="{{ filter.min_value.param_name }}"
              value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
            >
          {% endif %}

          {% if filter.max_value.value != blank %}
            <input
              type="hidden"
              name="{{ filter.max_value.param_name }}"
              value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
            >
          {% endif %}
        {% else %}
          {% for active_value in filter.active_values %}
            <input
              type="hidden"
              name="{{ active_value.param_name }}"
              value="{{ active_value.value }}"
            >
          {% endfor %}
        {% endif %}
      {% endfor %}
      <label for="collection-sort">{{ 'collections.sort_by' | t }}</label>

      <select id="collection-sort" name="sort_by" onchange="this.form.requestSubmit()">
        {% for option in collection.sort_options %}
          <option
            value="{{ option.value }}"
            {% if option.value == current_sort %}
              selected
            {% endif %}
          >
            {{ option.name }}
          </option>
        {% endfor %}
      </select>
    </form>
  </div>
  {% if collection.filters.size > 0 %}
    {% if active_filter_count > 0 %}
      <div class="collection-active-filters">
        {% for filter in collection.filters %}
          {% case filter.type %}
            {% when 'price_range' %}
              {% if filter.min_value.value != blank or filter.max_value.value != blank %}
                <a class="collection-active-filter" href="{{ filter.url_to_remove }}">
                  {{ filter.label }}:
                  {% if filter.min_value.value != blank %}
                    {{ filter.min_value.value | money }}
                  {% else %}
                    {{ 0 | money }}
                  {% endif %}
                  -
                  {% if filter.max_value.value != blank %}
                    {{ filter.max_value.value | money }}
                  {% else %}
                    {{ filter.range_max | money }}
                  {% endif %}
                  <span aria-hidden="true">&times;</span>
                </a>
              {% endif %}

            {% else %}
              {% for active_value in filter.active_values %}
                <a class="collection-active-filter" href="{{ active_value.url_to_remove }}">
                  {{ filter.label }}: {{ active_value.label }}
                  <span aria-hidden="true">&times;</span>
                </a>
              {% endfor %}
          {% endcase %}
        {% endfor %}
        <a class="collection-active-filters__clear" href="{{ collection.url }}?sort_by={{ current_sort | url_encode }}">
          {{ 'collections.clear_all' | t }}
        </a>
      </div>
    {% endif %}

    <button class="collection-filters__overlay" type="button" data-collection-filter-close aria-label="{{ 'accessibility.close' | t }}"></button>
    <form class="collection-filters" method="get" data-collection-filters>
      <div class="collection-filters__header">
        <strong>{{ 'collections.filters' | t }}</strong>
        <button type="button" data-collection-filter-close aria-label="{{ 'accessibility.close' | t }}">&times;</button>
      </div>
      {% if current_sort != blank %}
        <input type="hidden" name="sort_by" value="{{ current_sort }}">
      {% endif %}

      {% for filter in collection.filters %}
        <fieldset class="collection-filter">
          <legend class="collection-filter__legend">{{ filter.label }}</legend>

          {% case filter.type %}
            {% when 'price_range' %}
              {% assign max_price = filter.range_max | money_without_currency | replace: ',', '' %}
              {% assign min_value = '' %}
              {% assign max_value = '' %}

              {% if filter.min_value.value != blank %}
                {% assign min_value = filter.min_value.value | money_without_currency | replace: ',', '' %}
              {% endif %}

              {% if filter.max_value.value != blank %}
                {% assign max_value = filter.max_value.value | money_without_currency | replace: ',', '' %}
              {% endif %}

              <div class="collection-filter__price">
                <label class="collection-filter__price-field">
                  <span>Min</span>
                  <input
                    type="number"
                    name="{{ filter.min_value.param_name }}"
                    value="{{ min_value }}"
                    min="0"
                    max="{{ max_price }}"
                    placeholder="0"
                  >
                </label>

                <label class="collection-filter__price-field">
                  <span>Max</span>
                  <input
                    type="number"
                    name="{{ filter.max_value.param_name }}"
                    value="{{ max_value }}"
                    min="0"
                    max="{{ max_price }}"
                    placeholder="{{ max_price }}"
                  >
                </label>
              </div>

            {% else %}
              {% for value in filter.values %}
                <label class="collection-filter__value">
                  <input
                    class="collection-filter__checkbox"
                    type="checkbox"
                    name="{{ value.param_name }}"
                    value="{{ value.value }}"
                    onchange="this.form.requestSubmit()"
                    {% if value.active %}
                      checked
                    {% endif %}
                    {% if value.count == 0 and value.active == false %}
                      disabled
                    {% endif %}
                  >
                  <span>{{ value.label }}</span>
                  <span class="collection-filter__count">({{ value.count }})</span>
                </label>
              {% endfor %}
          {% endcase %}
        </fieldset>
      {% endfor %}

      <div class="collection-filters__actions">
        <button type="submit">{{ 'collections.apply_filters' | t }}</button>

        {% if active_filter_count > 0 %}
          <a class="collection-filters__clear" href="{{ collection.url }}?sort_by={{ current_sort | url_encode }}">
            {{ 'collections.clear_all' | t }}
          </a>
        {% endif %}
      </div>
    </form>
  {% endif %}
  {% if paginate.items > 0 %}
    <div class="collection-products">
      {% for product in collection.products %}
        {% render 'product-card',
          product: product,
          show_vendor: section.settings.show_vendor,
          show_badges: section.settings.show_badges,
          show_secondary_image: section.settings.show_secondary_image,
          enable_quick_add: section.settings.enable_quick_add
        %}
      {% endfor %}
    </div>

    {% render 'pagination', paginate: paginate, class: 'collection-pagination' %}
  {% else %}
    <p class="collection-empty">{{ 'collections.empty' | t }}</p>
  {% endif %}
{% endpaginate %}
</div>

{% stylesheet %}
  .collection-toolbar {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    margin-block: 1.5rem;
  }

  .collection-toolbar--sticky {
    position: sticky;
    z-index: 8;
    top: 0;
    padding-block: 0.75rem;
    background: var(--color-background);
  }

  .collection-filter-toggle,
  .collection-filters__header,
  .collection-filters__overlay {
    display: none;
  }

  .collection-product-count {
    color: rgb(92, 95, 98);
  }

  .collection-search-form {
    position: relative;
    display: grid;
    gap: 0.35rem;
    min-width: min(100%, 320px);
  }

  .collection-search-form label {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .collection-search-form__row {
    display: flex;
    gap: 0.5rem;
  }

  .collection-search-form input[type='search'] {
    min-height: 40px;
    min-width: 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .collection-search-form button {
    min-height: 40px;
    padding: 0.5rem 0.9rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .collection-sort-form {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .collection-sort-form select {
    min-height: 40px;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
  }

  .collection-filters {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .collection-filter {
    display: grid;
    gap: 0.6rem;
    min-width: 0;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 4px;
  }

  .collection-filter__legend {
    padding-inline: 0.25rem;
    font-weight: 700;
  }

  .collection-filter__value {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.5rem;
    align-items: center;
    width: max-content;
    max-width: 100%;
  }

  .collection-filter__checkbox {
    width: 16px;
    height: 16px;
  }

  .collection-filter__count {
    color: rgb(92, 95, 98);
    font-size: 0.875rem;
  }

  .collection-filter__price {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .collection-filter__price-field {
    display: grid;
    gap: 0.35rem;
    min-width: 140px;
  }

  .collection-filter__price-field input {
    min-height: 40px;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .collection-filters__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .collection-filters__actions button {
    min-height: 40px;
    padding: 0.5rem 1rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
    cursor: pointer;
  }

  .collection-filters__clear {
    color: rgb(92, 95, 98);
    font-size: 0.875rem;
  }

  .collection-products {
    display: grid;
    grid-template-columns: repeat(var(--collection-columns-desktop), minmax(0, 1fr));
    gap: 1rem;
  }

  .collection-description {
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .collection-pagination {
    margin-top: 2rem;
  }

  .collection-pagination .pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .collection-empty {
    margin-block: 2rem;
  }
  .collection-active-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .collection-active-filter,
  .collection-active-filters__clear {
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
    min-height: 34px;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 4px;
    color: inherit;
    text-decoration: none;
  }

  .collection-active-filters__clear {
    color: rgb(92, 95, 98);
  }

  @media screen and (max-width: 749px) {
    .collection-toolbar {
      align-items: stretch;
      flex-direction: column;
    }

    .collection-sort-form {
      align-items: stretch;
      flex-direction: column;
    }

    .collection-search-form,
    .collection-search-form__row {
      width: 100%;
    }

    .collection-search-form__row {
      flex-direction: column;
    }

    .collection-search-form button {
      width: 100%;
    }

    .collection-filters__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .collection-filters__actions button,
    .collection-filters__clear {
      width: 100%;
    }

    .collection-filter-toggle {
      display: block;
      min-height: 42px;
    }

    .collection-products {
      grid-template-columns: repeat(var(--collection-columns-mobile), minmax(0, 1fr));
    }

    .collection-filters {
      position: fixed;
      z-index: 31;
      top: 0;
      right: 0;
      bottom: 0;
      display: none;
      width: min(90vw, 420px);
      overflow-y: auto;
      margin: 0;
      padding: 1rem;
      background: var(--color-background);
    }

    .collection-filters.is-open,
    .collection-filters__overlay.is-open {
      display: grid;
    }

    .collection-filters__overlay {
      position: fixed;
      z-index: 30;
      inset: 0;
      border: 0;
      background: rgba(0, 0, 0, 0.45);
    }

    .collection-filters__header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:labels.products_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:labels.show_search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "t:labels.show_badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:labels.show_secondary_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "t:labels.enable_quick_add",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:labels.columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:labels.columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "sticky_toolbar",
      "label": "t:labels.sticky_toolbar",
      "default": true
    }
  ]
}
{% endschema %}
