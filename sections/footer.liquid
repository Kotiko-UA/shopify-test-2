<footer
  class="site-footer"
  style="--footer-background: {{ section.settings.background_color }}; --footer-foreground: {{ section.settings.text_color }}; --footer-columns: {{ section.settings.columns_desktop }};"
>
  <div class="site-footer__grid">
    {% for block in section.blocks %}
      <div class="site-footer__block" {{ block.shopify_attributes }}>
        {% case block.type %}
          {% when 'menu' %}
            {% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}
            <ul>
              {% for link in block.settings.menu.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>

          {% when 'text' %}
            {% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}
            <div class="site-footer__text">{{ block.settings.text }}</div>

          {% when 'newsletter' %}
            {% assign footer_form_id = 'FooterNewsletter-' | append: section.id | append: '-' | append: block.id %}
            {% if block.settings.heading != blank %}<h2>{{ block.settings.heading | escape }}</h2>{% endif %}
            <div class="site-footer__text">{{ block.settings.text }}</div>
            {% form 'customer', id: footer_form_id, class: 'site-footer__newsletter' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              {% if form.posted_successfully? %}<p role="status">{{ 'newsletter.success' | t }}</p>{% endif %}
              {% if form.errors %}<div role="alert">{{ form.errors | default_errors }}</div>{% endif %}
              <label for="{{ footer_form_id }}-email">{{ 'newsletter.email' | t }}</label>
              <div>
                <input id="{{ footer_form_id }}-email" type="email" name="contact[email]" autocomplete="email" required>
                <button type="submit">{{ block.settings.button_label | escape }}</button>
              </div>
            {% endform %}

          {% when 'social_link' %}
            <a class="site-footer__social-link" href="{{ block.settings.link }}">
              {{ block.settings.platform | escape }}
            </a>
        {% endcase %}
      </div>
    {% endfor %}
  </div>

  <div class="site-footer__localization">
    {% if section.settings.show_country_selector and localization.available_countries.size > 1 %}
      {% form 'localization', class: 'site-footer__localization-form' %}
        <label for="FooterCountry-{{ section.id }}">{{ 'footer.country' | t }}</label>
        <select id="FooterCountry-{{ section.id }}" name="country_code" onchange="this.form.submit()">
          {% for country in localization.available_countries %}
            <option value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}selected{% endif %}>
              {{ country.name }} ({{ country.currency.iso_code }})
            </option>
          {% endfor %}
        </select>
      {% endform %}
    {% endif %}

    {% if section.settings.show_language_selector and localization.available_languages.size > 1 %}
      {% form 'localization', class: 'site-footer__localization-form' %}
        <label for="FooterLanguage-{{ section.id }}">{{ 'footer.language' | t }}</label>
        <select id="FooterLanguage-{{ section.id }}" name="language_code" onchange="this.form.submit()">
          {% for language in localization.available_languages %}
            <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
              {{ language.endonym_name }}
            </option>
          {% endfor %}
        </select>
      {% endform %}
    {% endif %}
  </div>

  {% if section.settings.show_policies %}
    <div class="site-footer__policies">
      {% for policy in shop.policies %}
        {% if policy != blank %}<a href="{{ policy.url }}">{{ policy.title }}</a>{% endif %}
      {% endfor %}
    </div>
  {% endif %}

  <div class="site-footer__bottom">
    <div>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | link_to: routes.root_url }}</div>
    {% if section.settings.show_payment_icons %}
      <div class="site-footer__payment">
        {% for type in shop.enabled_payment_types %}{{ type | payment_type_svg_tag }}{% endfor %}
      </div>
    {% endif %}
  </div>
</footer>

{% stylesheet %}
  .site-footer { margin-top: 2rem; padding: 3rem 1rem 1.5rem; background: var(--footer-background); color: var(--footer-foreground); }
  .site-footer a { color: inherit; }
  .site-footer__grid { display: grid; grid-template-columns: repeat(var(--footer-columns), minmax(0, 1fr)); gap: 2rem; }
  .site-footer__block { min-width: 0; }
  .site-footer__block h2 { margin: 0 0 0.75rem; font-size: 1rem; }
  .site-footer__block ul { display: grid; gap: 0.5rem; padding: 0; list-style: none; }
  .site-footer__block li a { text-decoration: none; }
  .site-footer__text { line-height: 1.6; }
  .site-footer__newsletter { display: grid; gap: 0.5rem; margin-top: 0.75rem; }
  .site-footer__newsletter > div { display: grid; grid-template-columns: minmax(0, 1fr) auto; }
  .site-footer__newsletter input, .site-footer__newsletter button, .site-footer__localization select { min-height: 42px; padding: 0.55rem 0.7rem; border: 1px solid currentcolor; border-radius: 4px; }
  .site-footer__social-link { display: inline-flex; font-weight: 700; }
  .site-footer__localization, .site-footer__policies, .site-footer__bottom, .site-footer__payment { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; }
  .site-footer__localization, .site-footer__policies, .site-footer__bottom { margin-top: 2rem; padding-top: 1rem; border-top: 1px solid color-mix(in srgb, currentcolor, transparent 80%); }
  .site-footer__localization-form { display: grid; gap: 0.35rem; }
  .site-footer__bottom { justify-content: space-between; }
  .site-footer__payment svg { width: 38px; }
  @media screen and (max-width: 749px) {
    .site-footer__grid { grid-template-columns: 1fr; }
    .site-footer__newsletter > div { grid-template-columns: 1fr; gap: 0.4rem; }
    .site-footer__bottom { align-items: flex-start; flex-direction: column; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    { "type": "range", "id": "columns_desktop", "label": "t:labels.columns_desktop", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_payment_icons", "label": "t:labels.show_payment_icons", "default": true },
    { "type": "checkbox", "id": "show_policies", "label": "t:labels.show_policies", "default": true },
    { "type": "checkbox", "id": "show_country_selector", "label": "t:labels.show_country_selector", "default": true },
    { "type": "checkbox", "id": "show_language_selector", "label": "t:labels.show_language_selector", "default": true },
    { "type": "color", "id": "background_color", "label": "t:labels.background", "default": "#f6f6f7" },
    { "type": "color", "id": "text_color", "label": "t:labels.text_color", "default": "#202223" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "t:general.footer_menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:labels.heading", "default": "Links" },
        { "type": "link_list", "id": "menu", "label": "t:labels.menu" }
      ]
    },
    {
      "type": "text",
      "name": "t:general.footer_text",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:labels.heading" },
        { "type": "richtext", "id": "text", "label": "t:labels.text" }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:general.footer_newsletter",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:labels.heading", "default": "Newsletter" },
        { "type": "richtext", "id": "text", "label": "t:labels.text" },
        { "type": "text", "id": "button_label", "label": "t:labels.button_label", "default": "Subscribe" }
      ]
    },
    {
      "type": "social_link",
      "name": "t:general.social_link",
      "settings": [
        { "type": "text", "id": "platform", "label": "t:labels.platform", "default": "Instagram" },
        { "type": "url", "id": "link", "label": "t:labels.link" }
      ]
    }
  ],
  "max_blocks": 12
}
{% endschema %}
