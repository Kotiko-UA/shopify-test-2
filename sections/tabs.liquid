<script src="{{ 'tabs.js' | asset_url }}" defer></script>

<section class="tabs-section">
  {% render 'section-header',
    eyebrow: section.settings.eyebrow,
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  <div class="tabs" data-tabs>
    <div
      class="tabs__buttons"
      role="tablist"
      aria-label="{{ section.settings.heading | default: 'Tabs' | escape }}"
      aria-orientation="horizontal"
      data-tab-list
    ></div>

    <div class="tabs__panels" data-tab-panels>
      {% content_for 'blocks' %}
    </div>
  </div>
</section>

{% stylesheet %}
  .tabs-section {
    padding-block: 3rem;
  }

  .tabs {
    display: grid;
    gap: 1rem;
  }

  .tabs__buttons {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-block: 0.25rem;
    scrollbar-width: thin;
  }

  .tabs:not([data-tabs-initialized='true']) .tabs__buttons {
    display: none;
  }

  .tabs__button {
    flex: 0 0 auto;
    min-height: 40px;
    padding: 0.6rem 1rem;
    border: 1px solid color-mix(in srgb, var(--color-foreground), transparent 65%);
    border-radius: 4px;
    background: var(--color-background);
    color: var(--color-foreground);
    font: inherit;
    cursor: pointer;
  }

  .tabs__button:hover {
    border-color: var(--color-foreground);
  }

  .tabs__button--active {
    border-color: var(--color-foreground);
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .tabs__button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .tabs__panels,
  .tabs__item,
  .tabs__panel-content {
    min-width: 0;
  }

  .tabs__item {
    display: grid;
    gap: 0.75rem;
  }

  .tabs__item > .tabs__button {
    justify-self: start;
  }

  .tabs__panel {
    padding-block: 1.25rem;
    border-top: 1px solid color-mix(in srgb, var(--color-foreground), transparent 78%);
    line-height: 1.6;
  }

  .tabs__panel-content {
    display: grid;
    gap: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.tabs",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "More information"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [{ "type": "_tab" }],
  "max_blocks": 10,
  "presets": [
    {
      "name": "t:general.tabs",
      "blocks": [
        {
          "type": "_tab",
          "settings": { "title": "Details" },
          "blocks": [
            {
              "type": "text",
              "settings": {
                "text": "Add product or page details here.",
                "text_style": "text--normal",
                "alignment": "left"
              }
            }
          ]
        },
        {
          "type": "_tab",
          "settings": { "title": "Shipping" },
          "blocks": [
            {
              "type": "text",
              "settings": {
                "text": "Add shipping and delivery information here.",
                "text_style": "text--normal",
                "alignment": "left"
              }
            }
          ]
        },
        {
          "type": "_tab",
          "settings": { "title": "Returns" },
          "blocks": [
            {
              "type": "text",
              "settings": {
                "text": "Add return policy information here.",
                "text_style": "text--normal",
                "alignment": "left"
              }
            }
          ]
        }
      ]
    }
  ]
}
{% endschema %}
