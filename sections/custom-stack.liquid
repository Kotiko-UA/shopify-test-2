{% comment %}
  Renders a flexible stack section that accepts theme blocks.
{% endcomment %}

<div
  class="custom-stack"
  style="
    --custom-stack-gap: {{ section.settings.gap }}px;
    --custom-stack-padding: {{ section.settings.padding }}px;
    --custom-stack-alignment: {{ section.settings.alignment }};
  "
>
  <div class="custom-stack__inner">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .custom-stack {
    padding: var(--custom-stack-padding) 16px;
  }

  .custom-stack__inner {
    display: flex;
    flex-direction: column;
    align-items: var(--custom-stack-alignment);
    gap: var(--custom-stack-gap);
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom stack",
  "blocks": [
    {
      "type": "@theme"
    }
  ],
  "settings": [
    {
      "type": "range",
      "id": "gap",
      "label": "Gap",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Vertical padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    }
  ],
  "presets": [
    {
      "name": "Custom stack"
    }
  ]
}
{% endschema %}
