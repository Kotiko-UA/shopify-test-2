{% comment %}
  This section is used in the blog template to render the blog page listing all
  articles within a blog.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/blog
{% endcomment %}

{% liquid
  assign show_blog_search = section.settings.show_search
  if section.settings.show_search == nil
    assign show_blog_search = true
  endif

  assign show_blog_tag_filter = false
  if section.settings.show_tag_filter and blog.all_tags.size > 0
    assign show_blog_tag_filter = true
  endif

  assign has_blog_toolbar = false
  if show_blog_search or show_blog_tag_filter
    assign has_blog_toolbar = true
  endif

  assign blog_columns_desktop = section.settings.columns_desktop | default: 3
  assign blog_columns_mobile = section.settings.columns_mobile | default: 1
  assign blog_grid_gap = section.settings.grid_gap | default: 16
  assign article_excerpt_length = section.settings.excerpt_length | default: 160
  assign blog_search_label = 'blog.search_articles' | t
  assign blog_search_placeholder = 'blog.search_placeholder' | t
  assign search_submit_label = 'search.submit' | t
%}

{% if show_blog_search %}
  {{ 'predictive-search.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
{% endif %}
{% if show_blog_tag_filter %}
  <script src="{{ 'blog.js' | asset_url }}" defer></script>
{% endif %}

<div
  class="blog-page"
  style="
    --blog-columns-desktop: {{ blog_columns_desktop }};
    --blog-columns-mobile: {{ blog_columns_mobile }};
    --blog-grid-gap: {{ blog_grid_gap }}px;
  "
>
  <header class="blog-page__header">
    <h1>{{ blog.title | escape }}</h1>

    {% if current_tags.size > 0 %}
      {% assign active_tags = current_tags | join: ', ' %}
      <p class="blog-page__active-tags">{{ 'blog.filtered_by' | t: tags: active_tags }}</p>
    {% endif %}
  </header>

  {% if has_blog_toolbar %}
    <div class="blog-toolbar{% if show_blog_search and show_blog_tag_filter %} blog-toolbar--split{% endif %}">
      {% if show_blog_search %}
        {% render 'predictive-search-form',
          input_id: 'BlogArticleSearch',
          panel_id: 'blog-predictive-search',
          types: 'article',
          class: 'blog-search',
          form_class: 'blog-search-form',
          row_class: 'blog-search-form__row',
          label: blog_search_label,
          placeholder: blog_search_placeholder,
          button_label: search_submit_label
        %}
      {% endif %}

      {% if show_blog_tag_filter %}
        <div class="blog-toolbar__field">
          <label for="BlogTagFilter">{{ 'blog.filter_by_tag' | t }}</label>
          <select id="BlogTagFilter" data-blog-tag-select>
            <option value="{{ blog.url }}">{{ 'blog.all_articles' | t }}</option>
            {% for tag in blog.all_tags %}
              {% assign tag_handle = tag | handleize %}
              <option
                value="{{ blog.url }}/tagged/{{ tag_handle }}"
                {% if current_tags contains tag %}
                  selected
                {% endif %}
              >
                {{ tag }}
              </option>
            {% endfor %}
          </select>
        </div>
      {% endif %}
    </div>
  {% endif %}

  {% if show_blog_tag_filter %}
    <nav class="blog-tags" aria-label="{{ 'blog.tags' | t }}">
      <a
        class="blog-tags__link{% if current_tags.size == 0 %} blog-tags__link--active{% endif %}"
        href="{{ blog.url }}"
      >
        {{ 'blog.all_articles' | t }}
      </a>

      {% for tag in blog.all_tags %}
        {% assign tag_handle = tag | handleize %}
        <a
          class="blog-tags__link{% if current_tags contains tag %} blog-tags__link--active{% endif %}"
          href="{{ blog.url }}/tagged/{{ tag_handle }}"
        >
          {{ tag }}
        </a>
      {% endfor %}
    </nav>
  {% endif %}

  {% paginate blog.articles by section.settings.articles_per_page %}
    {% if paginate.items > 0 %}
      {% assign has_featured_article = false %}
      {% if section.settings.feature_first_article and paginate.current_page == 1 %}
        {% assign has_featured_article = true %}
        <div class="blog-featured-article">
          {% for article in blog.articles limit: 1 %}
            {% render 'article-card',
              article: article,
              show_image: section.settings.show_image,
              show_excerpt: section.settings.show_excerpt,
              show_author: section.settings.show_author,
              show_date: section.settings.show_date,
              show_tags: section.settings.show_article_tags,
              excerpt_length: article_excerpt_length,
              class: 'article-card--featured'
            %}
          {% endfor %}
        </div>
      {% endif %}

      {% if has_featured_article == false or paginate.items > 1 %}
        <div class="blog-grid">
          {% if has_featured_article %}
            {% for article in blog.articles offset: 1 %}
              {% render 'article-card',
                article: article,
                show_image: section.settings.show_image,
                show_excerpt: section.settings.show_excerpt,
                show_author: section.settings.show_author,
                show_date: section.settings.show_date,
                show_tags: section.settings.show_article_tags,
                excerpt_length: article_excerpt_length
              %}
            {% endfor %}
          {% else %}
            {% for article in blog.articles %}
              {% render 'article-card',
                article: article,
                show_image: section.settings.show_image,
                show_excerpt: section.settings.show_excerpt,
                show_author: section.settings.show_author,
                show_date: section.settings.show_date,
                show_tags: section.settings.show_article_tags,
                excerpt_length: article_excerpt_length
              %}
            {% endfor %}
          {% endif %}
        </div>
      {% endif %}

      {% render 'pagination', paginate: paginate, class: 'blog-pagination' %}
    {% else %}
      <p class="blog-empty">{{ 'blog.empty' | t }}</p>
    {% endif %}
  {% endpaginate %}
</div>

{% stylesheet %}
  .blog-page {
    width: min(100% - 2rem, 1200px);
    margin-inline: auto;
    padding-block: 2rem;
  }

  .blog-page__header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-page__active-tags {
    color: rgb(92, 95, 98);
  }

  .blog-toolbar {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .blog-toolbar--split {
    grid-template-columns: minmax(260px, 1fr) minmax(180px, auto);
  }

  .blog-search-form,
  .blog-toolbar__field {
    position: relative;
    display: grid;
    gap: 0.35rem;
  }

  .blog-search-form label,
  .blog-toolbar__field label {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .blog-search-form__row {
    display: flex;
    gap: 0.5rem;
  }

  .blog-search-form input[type='search'],
  .blog-toolbar__field select {
    min-height: 40px;
    min-width: 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .blog-search-form input[type='search'] {
    flex: 1;
  }

  .blog-search-form button {
    min-height: 40px;
    padding: 0.5rem 0.9rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-tags__link {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 4px;
    color: inherit;
    text-decoration: none;
  }

  .blog-tags__link--active {
    border-color: rgb(32, 34, 35);
    font-weight: 700;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(var(--blog-columns-mobile), minmax(0, 1fr));
    gap: var(--blog-grid-gap);
  }

  .blog-featured-article {
    margin-bottom: var(--blog-grid-gap);
  }

  .blog-pagination {
    margin-top: 2rem;
  }

  .blog-pagination .pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .blog-empty {
    margin-block: 2rem;
  }

  @media screen and (max-width: 900px) {
    .blog-toolbar--split {
      grid-template-columns: 1fr;
    }

    .blog-search-form__row {
      flex-direction: column;
    }

    .blog-search-form button {
      width: 100%;
    }
  }

  @media screen and (min-width: 750px) {
    .blog-grid {
      grid-template-columns: repeat(var(--blog-columns-desktop), minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "t:labels.articles_per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:labels.show_search",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:labels.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:labels.show_excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:labels.show_author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:labels.show_date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_article_tags",
      "label": "t:labels.show_article_tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "feature_first_article",
      "label": "t:labels.feature_first_article",
      "default": true
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:labels.columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "t:labels.columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "t:labels.grid_gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "label": "t:labels.excerpt_length",
      "min": 80,
      "max": 260,
      "step": 20,
      "default": 160
    },
    {
      "type": "checkbox",
      "id": "show_tag_filter",
      "label": "t:labels.show_tag_filter",
      "default": true
    }
  ]
}
{% endschema %}
