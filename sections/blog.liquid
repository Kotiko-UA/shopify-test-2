{% comment %}
  This section is used in the blog template to render the blog page listing all
  articles within a blog.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/blog
{% endcomment %}

<script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
<script src="{{ 'blog.js' | asset_url }}" defer></script>

<div class="blog-page">
  <header class="blog-page__header">
    <h1>{{ blog.title | escape }}</h1>

    {% if current_tags.size > 0 %}
      {% assign active_tags = current_tags | join: ', ' %}
      <p class="blog-page__active-tags">{{ 'blog.filtered_by' | t: tags: active_tags }}</p>
    {% endif %}
  </header>

  <div class="blog-toolbar">
    <predictive-search
      class="blog-search"
      data-predictive-search-url="{{ routes.predictive_search_url }}"
      data-predictive-search-types="article"
    >
      <form class="blog-search-form" action="{{ routes.search_url }}" method="get" role="search">
        <label for="BlogArticleSearch">{{ 'blog.search_articles' | t }}</label>
        <div class="blog-search-form__row">
          <input
            id="BlogArticleSearch"
            type="search"
            name="q"
            placeholder="{{ 'blog.search_placeholder' | t }}"
            autocomplete="off"
            role="combobox"
            aria-expanded="false"
            aria-controls="blog-predictive-search"
            aria-haspopup="listbox"
            data-predictive-search-input
          >
          <input type="hidden" name="type" value="article">
          <input type="hidden" name="options[prefix]" value="last">
          <button type="submit">{{ 'search.submit' | t }}</button>
        </div>

        <div
          id="blog-predictive-search"
          class="predictive-search__panel"
          tabindex="-1"
          data-predictive-search-results
          hidden
        ></div>
      </form>
    </predictive-search>

    {% if section.settings.show_tag_filter and blog.all_tags.size > 0 %}
      <div class="blog-toolbar__field">
        <label for="BlogTagFilter">{{ 'blog.filter_by_tag' | t }}</label>
        <select id="BlogTagFilter" data-blog-tag-select>
          <option value="{{ blog.url }}">{{ 'blog.all_articles' | t }}</option>
          {% for tag in blog.all_tags %}
            {% assign tag_handle = tag | handleize %}
            <option
              value="{{ blog.url }}/tagged/{{ tag_handle }}"
              {% if current_tags contains tag %}
                selected
              {% endif %}
            >
              {{ tag }}
            </option>
          {% endfor %}
        </select>
      </div>
    {% endif %}

  </div>

  {% if section.settings.show_tag_filter and blog.all_tags.size > 0 %}
    <nav class="blog-tags" aria-label="{{ 'blog.tags' | t }}">
      <a
        class="blog-tags__link{% if current_tags.size == 0 %} blog-tags__link--active{% endif %}"
        href="{{ blog.url }}"
      >
        {{ 'blog.all_articles' | t }}
      </a>

      {% for tag in blog.all_tags %}
        {% assign tag_handle = tag | handleize %}
        <a
          class="blog-tags__link{% if current_tags contains tag %} blog-tags__link--active{% endif %}"
          href="{{ blog.url }}/tagged/{{ tag_handle }}"
        >
          {{ tag }}
        </a>
      {% endfor %}
    </nav>
  {% endif %}

  {% paginate blog.articles by section.settings.articles_per_page %}
    {% if paginate.items > 0 %}
      <div class="blog-grid">
        {% for article in blog.articles %}
          {% render 'article-card',
            article: article,
            show_image: section.settings.show_image,
            show_excerpt: section.settings.show_excerpt,
            show_author: section.settings.show_author,
            show_date: section.settings.show_date,
            show_tags: section.settings.show_article_tags
          %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="blog-pagination">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% else %}
      <p class="blog-empty">{{ 'blog.empty' | t }}</p>
    {% endif %}
  {% endpaginate %}
</div>

{% stylesheet %}
  .blog-page {
    width: min(100% - 2rem, 1200px);
    margin-inline: auto;
    padding-block: 2rem;
  }

  .blog-page__header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-page__active-tags {
    color: rgb(92, 95, 98);
  }

  .blog-toolbar {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(180px, auto);
    gap: 1rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .blog-search-form,
  .blog-toolbar__field {
    position: relative;
    display: grid;
    gap: 0.35rem;
  }

  .blog-search-form label,
  .blog-toolbar__field label {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .blog-search-form__row {
    display: flex;
    gap: 0.5rem;
  }

  .blog-search-form input[type='search'],
  .blog-toolbar__field select {
    min-height: 40px;
    min-width: 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .blog-search-form input[type='search'] {
    flex: 1;
  }

  .blog-search-form button {
    min-height: 40px;
    padding: 0.5rem 0.9rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-tags__link {
    display: inline-flex;
    min-height: 34px;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 4px;
    color: inherit;
    text-decoration: none;
  }

  .blog-tags__link--active {
    border-color: rgb(32, 34, 35);
    font-weight: 700;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .blog-pagination {
    margin-top: 2rem;
  }

  .blog-pagination .pagination {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .blog-empty {
    margin-block: 2rem;
  }

  @media screen and (max-width: 900px) {
    .blog-toolbar {
      grid-template-columns: 1fr;
    }

    .blog-search-form__row {
      flex-direction: column;
    }

    .blog-search-form button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "t:labels.articles_per_page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:labels.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:labels.show_excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:labels.show_author",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:labels.show_date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_article_tags",
      "label": "t:labels.show_article_tags",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tag_filter",
      "label": "t:labels.show_tag_filter",
      "default": true
    }
  ]
}
{% endschema %}
