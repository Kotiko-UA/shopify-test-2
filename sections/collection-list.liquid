<section class="collection-list">
  {% render 'section-header',
    eyebrow: section.settings.eyebrow,
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  <div class="collection-list__grid">
    {% for block in section.blocks %}
      {% assign collection = block.settings.collection %}

      {% if collection != blank %}
        {% assign collection_image = collection.image | default: collection.products.first.featured_image %}

        <article class="collection-list-card" {{ block.shopify_attributes }}>
          {% if collection_image != blank %}
            {% render 'image',
              class: 'collection-list-card__image',
              image: collection_image,
              url: collection.url,
              link_label: collection.title,
              decorative: true,
              width: 800,
              height: 620,
              crop: 'center',
              widths: '300, 500, 650, 800',
              sizes: '(min-width: 990px) 25vw, 50vw'
            %}
          {% endif %}

          <div class="collection-list-card__content">
            <h3>
              <a href="{{ collection.url }}">{{ collection.title | escape }}</a>
            </h3>
            <p>{{ 'sections.collection_list.product_count' | t: count: collection.products_count }}</p>
          </div>
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .collection-list {
    padding-block: 3rem;
  }

  .collection-list__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .collection-list-card {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: white;
  }

  .collection-list-card__image img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .collection-list-card__content {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
  }

  .collection-list-card h3,
  .collection-list-card p {
    margin: 0;
  }

  .collection-list-card a {
    color: inherit;
    text-decoration: none;
  }

  .collection-list-card p {
    color: rgb(92, 95, 98);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection_list",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop collections"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:general.collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:labels.collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.collection_list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
