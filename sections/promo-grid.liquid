<section class="promo-grid">
  {% render 'section-header',
    eyebrow: section.settings.eyebrow,
    heading: section.settings.heading,
    text: section.settings.description,
    alignment: section.settings.alignment
  %}

  <div class="promo-grid__items">
    {% for block in section.blocks %}
      <article class="promo-card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {% render 'image',
            class: 'promo-card__image',
            image: block.settings.image,
            alt: block.settings.heading,
            width: 900,
            height: 620,
            crop: 'center',
            widths: '300, 500, 700, 900',
            sizes: '(min-width: 990px) 33vw, 100vw'
          %}
        {% endif %}

        <div class="promo-card__content">
          {% if block.settings.heading != blank %}
            <h3>{{ block.settings.heading | escape }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="promo-card__text">{{ block.settings.text }}</div>
          {% endif %}

          {% if block.settings.button_label != blank and block.settings.link != blank %}
            <a href="{{ block.settings.link }}">{{ block.settings.button_label | escape }}</a>
          {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .promo-grid {
    padding-block: 3rem;
  }

  .promo-grid__items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .promo-card {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: white;
  }

  .promo-card__image img {
    aspect-ratio: 16 / 11;
    object-fit: cover;
  }

  .promo-card__content {
    display: grid;
    gap: 0.75rem;
    padding: 1rem;
  }

  .promo-card h3 {
    margin: 0;
  }

  .promo-card__text {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }

  .promo-card a {
    font-weight: 700;
    color: inherit;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.promo_grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop by category"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "promo",
      "name": "t:general.promo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Promo title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:labels.text",
          "default": "<p>Add a short promo message.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:labels.button_label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.promo_grid",
      "blocks": [
        { "type": "promo" },
        { "type": "promo" },
        { "type": "promo" }
      ]
    }
  ]
}
{% endschema %}
