<script src="{{ 'product-recommendations.js' | asset_url }}" defer></script>

{% if product != blank %}
  <section
    class="product-recommendations"
    data-product-recommendations
    data-recommendations-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.product_limit }}"
  >
    {% render 'section-header',
      heading: section.settings.heading,
      text: section.settings.description,
      alignment: section.settings.alignment
    %}

    <div class="product-recommendations__grid" data-product-recommendations-list>
      {% if recommendations.performed and recommendations.products_count > 0 %}
        {% for recommended_product in recommendations.products %}
          {% render 'product-card',
            product: recommended_product,
            show_vendor: section.settings.show_vendor,
            show_badges: section.settings.show_badges,
            show_secondary_image: section.settings.show_secondary_image,
            enable_quick_add: section.settings.enable_quick_add
          %}
        {% endfor %}
      {% endif %}
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .product-recommendations {
    padding-block: 3rem;
  }

  .product-recommendations:has(.product-recommendations__grid:empty) {
    display: none;
  }

  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product_recommendations",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "You may also like"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "t:labels.product_limit",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "t:labels.show_badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:labels.show_secondary_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "t:labels.enable_quick_add",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    }
  ],
  "presets": [{ "name": "t:general.product_recommendations" }]
}
{% endschema %}
