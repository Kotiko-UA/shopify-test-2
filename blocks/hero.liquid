{% liquid
  assign hero_image_loading = 'lazy'
  assign hero_fetchpriority = ''

  if block.settings.prioritize_image
    assign hero_image_loading = 'eager'
    assign hero_fetchpriority = 'high'
  endif

  assign hero_overlay_alpha = block.settings.overlay_opacity | divided_by: 100.0
  assign hero_overlay_color = block.settings.overlay_color | color_modify: 'alpha', hero_overlay_alpha
%}

<div
  class="hero hero--{{ block.settings.layout }} hero--image-{{ block.settings.image_position }} hero--content-{{ block.settings.content_position }}{% if block.settings.mobile_image != blank %} hero--has-mobile-image{% endif %}"
  style="
    --hero-background: {{ block.settings.background_color }};
    --hero-foreground: {{ block.settings.text_color }};
    --hero-padding: {{ block.settings.padding }}px;
    --hero-min-height: {{ block.settings.min_height }}px;
    --hero-overlay: {{ hero_overlay_color }};
  "
 {{ block.shopify_attributes }}>
  {% if block.settings.video != blank or block.settings.image != blank %}
    <div class="hero__media">
      {% if block.settings.video != blank %}
        {{
          block.settings.video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            controls: block.settings.show_video_controls,
            image_size: '1600x'
        }}
      {% else %}
        {% render 'image',
          class: 'hero__image hero__image--desktop',
          image: block.settings.image,
          alt: block.settings.heading,
          loading: hero_image_loading,
          fetchpriority: hero_fetchpriority,
          width: 1600,
          height: 1200,
          crop: 'center',
          widths: '500, 750, 1000, 1200, 1600',
          sizes: '(min-width: 990px) 50vw, 100vw'
        %}
        {% if block.settings.mobile_image != blank %}
          {% render 'image',
            class: 'hero__image hero__image--mobile',
            image: block.settings.mobile_image,
            alt: block.settings.heading,
            loading: hero_image_loading,
            width: 900,
            height: 1100,
            crop: 'center',
            widths: '400, 600, 750, 900',
            sizes: '100vw'
          %}
        {% endif %}
      {% endif %}
    </div>
  {% endif %}

  <div class="hero__content">
    {% if block.settings.eyebrow != blank %}
      <p class="hero__eyebrow">{{ block.settings.eyebrow | escape }}</p>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h1>{{ block.settings.heading | escape }}</h1>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="hero__description">
        {{ block.settings.description }}
      </div>
    {% endif %}

    <div class="hero__actions">
      {% if block.settings.primary_label != blank and block.settings.primary_link != blank %}
        {% render 'main-button',
          label: block.settings.primary_label,
          url: block.settings.primary_link,
          variant: block.settings.primary_variant
        %}
      {% endif %}

      {% if block.settings.secondary_label != blank and block.settings.secondary_link != blank %}
        {% render 'main-button',
          label: block.settings.secondary_label,
          url: block.settings.secondary_link,
          variant: 'secondary'
        %}
      {% endif %}
    </div>
  </div>

</div>

{% stylesheet %}
  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.9fr);
    gap: 2rem;
    align-items: center;
    padding: var(--hero-padding) 0;
    min-height: var(--hero-min-height);
    background-color: var(--hero-background);
    color: var(--hero-foreground);
  }

  .hero--split.hero--image-left .hero__media {
    order: -1;
  }

  .hero--split.hero--image-right .hero__media {
    order: 2;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 1rem;
    max-width: 680px;
  }

  .hero--content-center .hero__content {
    justify-self: center;
    text-align: center;
  }

  .hero--content-right .hero__content {
    justify-self: end;
    text-align: right;
  }

  .hero--background {
    grid-template-columns: minmax(0, 1fr);
    padding-inline: clamp(1rem, 6vw, 6rem);
    overflow: hidden;
  }

  .hero--background .hero__media {
    position: absolute;
    z-index: 0;
    inset: 0;
  }

  .hero--background::after {
    position: absolute;
    z-index: 1;
    inset: 0;
    background: var(--hero-overlay);
    content: '';
  }

  .hero__eyebrow {
    margin: 0;
    color: inherit;
    opacity: 0.75;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(2.4rem, 7vw, 5rem);
    line-height: 0.98;
  }

  .hero__description {
    max-width: 62ch;
    color: inherit;
    opacity: 0.86;
    line-height: 1.6;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .hero__actions .main-button {
    margin-top: 0;
  }

  .hero__media,
  .hero__media video {
    width: 100%;
    height: 100%;
  }

  .hero__media video,
  .hero__image img {
    display: block;
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
  }

  .hero--background .hero__media video,
  .hero--background .hero__image,
  .hero--background .hero__image img {
    height: 100%;
    border-radius: 0;
  }

  .hero__image--mobile {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .hero {
      grid-template-columns: 1fr;
      padding: calc(var(--hero-padding) * 0.65) 0;
    }

    .hero h1 {
      max-width: none;
    }

    .hero__image--mobile {
      display: block;
    }

    .hero--has-mobile-image .hero__image--desktop {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "New collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Build your next storefront"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Use this section for a strong first impression, campaign landing page, or featured collection intro.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    { "type": "image_picker", "id": "mobile_image", "label": "t:labels.mobile_image" },
    { "type": "video", "id": "video", "label": "t:labels.video" },
    { "type": "checkbox", "id": "show_video_controls", "label": "t:labels.show_video_controls", "default": false },
    {
      "type": "select",
      "id": "layout",
      "label": "t:labels.layout",
      "options": [
        { "value": "split", "label": "t:options.hero_layout.split" },
        { "value": "background", "label": "t:options.hero_layout.background" }
      ],
      "default": "split"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "options": [
        { "value": "right", "label": "t:options.position.right" },
        { "value": "left", "label": "t:options.position.left" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "t:labels.content_position",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "prioritize_image",
      "label": "t:labels.prioritize_image",
      "default": true
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "t:labels.primary_button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "t:labels.primary_button_link"
    },
    {
      "type": "select",
      "id": "primary_variant",
      "label": "t:labels.button_variant",
      "options": [
        { "value": "primary", "label": "t:general.primary" },
        { "value": "accent", "label": "t:general.accent" }
      ],
      "default": "primary"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "t:labels.secondary_button_label"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "t:labels.secondary_button_link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#f6f6f7"
    },
    { "type": "color", "id": "text_color", "label": "t:labels.text_color", "default": "#202223" },
    { "type": "color", "id": "overlay_color", "label": "t:labels.overlay_color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "t:labels.overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 25 },
    { "type": "range", "id": "min_height", "label": "t:labels.minimum_height", "min": 360, "max": 900, "step": 20, "unit": "px", "default": 560 },
    {
      "type": "range",
      "id": "padding",
      "label": "t:labels.padding",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [{ "name": "t:general.hero" }]
}
{% endschema %}
