{% liquid
  assign featured_blog = block.settings.blog
  assign has_featured_blog_articles = false
  if featured_blog != blank and featured_blog.articles_count > 0
    assign has_featured_blog_articles = true
  endif

  assign should_render_featured_blog_header = has_featured_blog_articles
  if request.design_mode
    assign should_render_featured_blog_header = true
  endif

  assign featured_blog_columns_desktop = block.settings.columns_desktop | default: 3
  assign featured_blog_grid_gap = block.settings.grid_gap | default: 16
  assign article_excerpt_length = block.settings.excerpt_length | default: 160
%}

<div
  class="featured-blog"
  style="
    --featured-blog-columns-desktop: {{ featured_blog_columns_desktop }};
    --featured-blog-grid-gap: {{ featured_blog_grid_gap }}px;
  "
  {{ block.shopify_attributes }}
>
  {% if should_render_featured_blog_header %}
    {% render 'section-header',
      eyebrow: block.settings.eyebrow,
      heading: block.settings.heading,
      text: block.settings.description,
      alignment: block.settings.alignment
    %}
  {% endif %}

  {% if has_featured_blog_articles %}
    <div class="featured-blog__grid">
      {% for article in featured_blog.articles limit: block.settings.article_limit %}
        {% render 'article-card',
          article: article,
          show_image: block.settings.show_image,
          show_excerpt: block.settings.show_excerpt,
          show_author: block.settings.show_author,
          show_date: block.settings.show_date,
          show_tags: block.settings.show_tags,
          excerpt_length: article_excerpt_length
        %}
      {% endfor %}
    </div>

    {% if block.settings.button_label != blank %}
      <div class="featured-blog__footer">
        {% render 'main-button',
          label: block.settings.button_label,
          url: featured_blog.url,
          variant: block.settings.button_variant
        %}
      </div>
    {% endif %}
  {% elsif request.design_mode %}
    <p class="featured-blog__empty">{{ 'sections.featured_blog.empty' | t }}</p>
  {% endif %}
</div>

{% stylesheet %}
  .featured-blog {
    width: 100%;
  }

  .featured-blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--featured-blog-grid-gap);
  }

  .featured-blog__footer {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .featured-blog__footer .main-button {
    margin-top: 0;
  }

  .featured-blog__empty {
    padding: 1rem;
    border: 1px dashed rgb(180, 180, 180);
    border-radius: 6px;
    color: rgb(92, 95, 98);
  }

  @media screen and (min-width: 750px) {
    .featured-blog__grid {
      grid-template-columns: repeat(var(--featured-blog-columns-desktop), minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_blog",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Latest articles"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "t:labels.blog"
    },
    {
      "type": "range",
      "id": "article_limit",
      "label": "t:labels.article_limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:labels.columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "t:labels.grid_gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "excerpt_length",
      "label": "t:labels.excerpt_length",
      "min": 80,
      "max": 260,
      "step": 20,
      "default": 160
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "t:labels.show_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "t:labels.show_excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "label": "t:labels.show_author",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "t:labels.show_date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "label": "t:labels.show_tags",
      "default": false
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "View all articles"
    },
    {
      "type": "select",
      "id": "button_variant",
      "label": "t:labels.button_variant",
      "options": [
        { "value": "primary", "label": "t:general.primary" },
        { "value": "secondary", "label": "t:general.secondary" },
        { "value": "accent", "label": "t:general.accent" }
      ],
      "default": "secondary"
    }
  ],
  "presets": [{ "name": "t:general.featured_blog" }]
}
{% endschema %}
