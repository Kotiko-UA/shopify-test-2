{% assign slider_label = block.settings.heading %}
{% if slider_label == blank %}
  {% assign slider_label = 'sections.product_slider.label' | t %}
{% endif %}

<div
  id="ProductSlider-{{ block.id }}"
  class="product-slider"
  role="region"
  aria-label="{{ slider_label | escape }}"
  data-product-slider
  data-swiper-script="{{ 'swiper-bundle.min.js' | asset_url }}"
  data-swiper-stylesheet="{{ 'swiper-bundle.min.css' | asset_url }}"
  data-slides-mobile="{{ block.settings.slides_mobile }}"
  data-slides-tablet="{{ block.settings.slides_tablet }}"
  data-slides-desktop="{{ block.settings.slides_desktop }}"
  data-space-between="{{ block.settings.space_between }}"
  data-enable-loop="{{ block.settings.enable_loop }}"
  data-previous-label="{{ 'sections.product_slider.previous' | t | escape }}"
  data-next-label="{{ 'sections.product_slider.next' | t | escape }}"
  {{ block.shopify_attributes }}
>
  {% render 'section-header',
    eyebrow: block.settings.eyebrow,
    heading: block.settings.heading,
    text: block.settings.description,
    alignment: block.settings.alignment
  %}

  {% if block.settings.products != blank %}
    <div class="product-slider__frame">
      <div class="product-slider__swiper swiper">
        <div class="swiper-wrapper">
          {% for product in block.settings.products %}
            {% if product != blank %}
              <div class="product-slider__item swiper-slide">
                {% render 'product-card',
                  product: product,
                  show_vendor: block.settings.show_vendor,
                  show_badges: block.settings.show_badges,
                  show_secondary_image: block.settings.show_secondary_image,
                  enable_quick_add: block.settings.enable_quick_add
                %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      {% if block.settings.show_navigation %}
        <button
          class="product-slider__button product-slider__button--previous"
          type="button"
          aria-label="{{ 'sections.product_slider.previous' | t | escape }}"
          title="{{ 'sections.product_slider.previous' | t | escape }}"
        >
          <span aria-hidden="true">&larr;</span>
        </button>
        <button
          class="product-slider__button product-slider__button--next"
          type="button"
          aria-label="{{ 'sections.product_slider.next' | t | escape }}"
          title="{{ 'sections.product_slider.next' | t | escape }}"
        >
          <span aria-hidden="true">&rarr;</span>
        </button>
      {% endif %}
    </div>

    {% if block.settings.show_pagination %}
      <div class="product-slider__pagination swiper-pagination"></div>
    {% endif %}
  {% elsif request.design_mode %}
    <p class="product-slider__empty">{{ 'sections.product_slider.empty' | t }}</p>
  {% endif %}
</div>

{% stylesheet %}
  .product-slider { width: 100%; }

  .product-slider__frame {
    position: relative;
  }

  .product-slider__swiper {
    overflow: hidden;
  }

  .product-slider__item {
    height: auto;
  }

  .product-slider__item .product-card {
    height: 100%;
  }

  .product-slider__button {
    position: absolute;
    z-index: 2;
    top: 50%;
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--color-foreground), transparent 65%);
    border-radius: 50%;
    background: var(--color-background);
    color: var(--color-foreground);
    font: inherit;
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    transform: translateY(-50%);
  }

  .product-slider__button--previous {
    left: 0.75rem;
  }

  .product-slider__button--next {
    right: 0.75rem;
  }

  .product-slider__button:hover {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .product-slider__button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 3px;
  }

  .product-slider__button.swiper-button-disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .product-slider__button.swiper-button-lock,
  .product-slider__pagination.swiper-pagination-lock {
    display: none;
  }

  .product-slider .product-slider__pagination.swiper-pagination {
    position: static;
    margin-top: 1rem;
    --swiper-pagination-color: var(--color-foreground);
    --swiper-pagination-bullet-inactive-color: var(--color-foreground);
  }

  .product-slider__empty {
    padding: 1rem;
    border: 1px dashed rgb(180, 180, 180);
    border-radius: 6px;
    color: rgb(92, 95, 98);
  }

  @media (max-width: 749px) {
    .product-slider__button {
      width: 2.5rem;
      height: 2.5rem;
    }

    .product-slider__button--previous {
      left: 0.5rem;
    }

    .product-slider__button--next {
      right: 0.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product_slider",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Selected products"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "t:general.products",
      "limit": 16
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "t:labels.show_badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:labels.show_secondary_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "t:labels.enable_quick_add",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:general.slider"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "t:labels.show_navigation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "t:labels.show_pagination",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "t:labels.enable_loop",
      "default": false
    },
    {
      "type": "select",
      "id": "slides_mobile",
      "label": "t:labels.slides_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "t:labels.slides_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "t:labels.slides_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "space_between",
      "label": "t:labels.space_between",
      "min": 0,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "t:general.product_slider"
    }
  ]
}
{% endschema %}
