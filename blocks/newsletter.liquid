{% comment %}
  Renders a reusable newsletter signup section.

  Newsletter signups use the `customer` form type and tag the created contact
  with `newsletter`.
{% endcomment %}

{% assign newsletter_form_id = 'NewsletterForm-' | append: block.id %}
{% assign newsletter_heading = block.settings.heading %}
{% assign newsletter_description = block.settings.description %}

{% if newsletter_heading == blank %}
  {% assign newsletter_heading = 'newsletter.heading' | t %}
{% endif %}

{% if newsletter_description == blank %}
  {% assign newsletter_description = 'newsletter.description_html' | t %}
{% endif %}

<div class="newsletter-section" {{ block.shopify_attributes }}>
  <div class="newsletter-section__content">
    {% if newsletter_heading != blank %}
      <h2>{{ newsletter_heading | escape }}</h2>
    {% endif %}

  {% if newsletter_description != blank %}
      <div class="newsletter-section__description">
        {{ newsletter_description }}
      </div>
    {% endif %}
  </div>

  {% render 'newsletter-form',
    id: newsletter_form_id,
    class: 'newsletter-form',
    label_class: 'newsletter-form__label',
    row_class: 'newsletter-form__row',
    success_class: 'newsletter-form__success',
    errors_class: 'newsletter-form__errors'
  %}
</div>

{% stylesheet %}
  .newsletter-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 480px);
    gap: 1.5rem;
    align-items: center;
    width: 100%;
    margin-inline: auto;
  }

  .newsletter-section__content {
    display: grid;
    gap: 0.75rem;
  }

  .newsletter-section__description {
    color: rgb(92, 95, 98);
    line-height: 1.6;
  }

  .newsletter-form {
    display: grid;
    gap: 0.75rem;
  }

  .newsletter-form__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
  }

  .newsletter-form__label {
    grid-column: 1 / -1;
    font-weight: 700;
  }

  .newsletter-form input {
    min-height: 44px;
    min-width: 0;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .newsletter-form button {
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .newsletter-form__success {
    padding: 0.75rem 1rem;
    border: 1px solid rgb(0, 128, 96);
    border-radius: 4px;
    color: rgb(0, 128, 96);
  }

  .newsletter-form__errors {
    padding: 0.75rem 1rem;
    border: 1px solid rgb(180, 38, 38);
    border-radius: 4px;
    color: rgb(180, 38, 38);
  }

  @media screen and (max-width: 749px) {
    .newsletter-section {
      grid-template-columns: 1fr;
    }

    .newsletter-form__row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    }
  ],
  "presets": [
    {
      "name": "t:general.newsletter"
    }
  ]
}
{% endschema %}
