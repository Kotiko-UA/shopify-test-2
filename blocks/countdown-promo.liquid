<script src="{{ 'countdown-promo.js' | asset_url }}" defer></script>

<div
  class="countdown-promo countdown-promo--{{ block.settings.alignment }}"
  data-countdown-promo
  data-countdown-end="{{ block.settings.end_datetime | escape }}"
  data-countdown-section-id="{{ block.id }}"
  data-countdown-evergreen-days="{{ block.settings.evergreen_days }}"
  data-countdown-completion-action="{{ block.settings.completion_action }}"
  data-countdown-redirect-url="{{ block.settings.redirect_url }}"
  style="
    --countdown-background: {{ block.settings.background_color }};
    --countdown-foreground: {{ block.settings.text_color }};
  "
 {{ block.shopify_attributes }}>
  {% render 'section-header',
    eyebrow: block.settings.eyebrow,
    heading: block.settings.heading,
    text: block.settings.description,
    alignment: block.settings.alignment
  %}

  <div class="countdown-promo__timer" aria-live="polite">
    <div class="countdown-promo__unit">
      <span data-countdown-days>00</span>
      <small>{{ 'sections.countdown.days' | t }}</small>
    </div>
    <div class="countdown-promo__unit">
      <span data-countdown-hours>00</span>
      <small>{{ 'sections.countdown.hours' | t }}</small>
    </div>
    <div class="countdown-promo__unit">
      <span data-countdown-minutes>00</span>
      <small>{{ 'sections.countdown.minutes' | t }}</small>
    </div>
    <div class="countdown-promo__unit">
      <span data-countdown-seconds>00</span>
      <small>{{ 'sections.countdown.seconds' | t }}</small>
    </div>
  </div>

  <p class="countdown-promo__invalid" data-countdown-invalid hidden>{{ 'sections.countdown.invalid_date' | t }}</p>
  <div class="countdown-promo__completion" data-countdown-completion hidden>{{ block.settings.completion_message }}</div>

  {% if block.settings.button_label != blank and block.settings.button_link != blank %}
    <div class="countdown-promo__action">
      {% render 'main-button',
        label: block.settings.button_label,
        url: block.settings.button_link,
        variant: block.settings.button_variant
      %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .countdown-promo {
    display: grid;
    gap: 1.5rem;
    justify-items: start;
    padding: 3rem 1.5rem;
    border-radius: 8px;
    background-color: var(--countdown-background);
    color: var(--countdown-foreground);
  }

  .countdown-promo--center {
    justify-items: center;
    text-align: center;
  }

  .countdown-promo--right {
    justify-items: end;
    text-align: right;
  }

  .countdown-promo .section-header {
    margin-bottom: 0;
  }

  .countdown-promo__timer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .countdown-promo__unit {
    display: grid;
    min-width: 76px;
    padding: 0.75rem;
    border: 1px solid currentcolor;
    border-radius: 6px;
    text-align: center;
  }

  .countdown-promo__unit span {
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1;
  }

  .countdown-promo__unit small {
    margin-top: 0.35rem;
    opacity: 0.72;
  }

  .countdown-promo__action .main-button {
    margin-top: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.countdown_promo",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Limited offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Sale ends soon"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Add urgency to launches, flash sales, and seasonal campaigns.</p>"
    },
    {
      "type": "text",
      "id": "end_datetime",
      "label": "t:labels.end_datetime",
      "info": "Use ISO format with timezone, for example 2026-12-31T23:59:00+02:00",
      "default": "2026-12-31T23:59:00+02:00"
    },
    { "type": "range", "id": "evergreen_days", "label": "t:labels.evergreen_days", "info": "Set above zero to start a personal countdown for each visitor.", "min": 0, "max": 30, "step": 1, "unit": "d", "default": 0 },
    {
      "type": "select",
      "id": "completion_action",
      "label": "t:labels.completion_action",
      "options": [
        { "value": "keep", "label": "t:options.countdown_completion.keep" },
        { "value": "hide", "label": "t:options.countdown_completion.hide" },
        { "value": "message", "label": "t:options.countdown_completion.message" },
        { "value": "redirect", "label": "t:options.countdown_completion.redirect" }
      ],
      "default": "keep"
    },
    { "type": "richtext", "id": "completion_message", "label": "t:labels.completion_message", "default": "<p>This offer has ended.</p>" },
    { "type": "url", "id": "redirect_url", "label": "t:labels.redirect_url" },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:labels.button_link"
    },
    {
      "type": "select",
      "id": "button_variant",
      "label": "t:labels.button_variant",
      "options": [
        { "value": "primary", "label": "t:general.primary" },
        { "value": "secondary", "label": "t:general.secondary" },
        { "value": "accent", "label": "t:general.accent" }
      ],
      "default": "accent"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#202223"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text_color",
      "default": "#ffffff"
    }
  ],
  "presets": [{ "name": "t:general.countdown_promo" }]
}
{% endschema %}
