{% doc %}
  Renders a small badge block.

  @example
  {% content_for 'block', type: 'badge', id: 'badge' %}
{% enddoc %}

{%- assign badge_variant = block.settings.variant | default: 'default' -%}

<span
  class="badge badge--{{ badge_variant }}"
  {{ block.shopify_attributes }}
>
  {{ block.settings.text }}
</span>

{% stylesheet %}
  .badge {
    display: inline-flex;
    width: fit-content;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .badge--default {
    background-color: rgb(238, 243, 255);
    color: rgb(32, 34, 35);
  }

  .badge--dark {
    background-color: rgb(32, 34, 35);
    color: rgb(255, 255, 255);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Badge",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Badge"
    },
    {
      "type": "select",
      "id": "variant",
      "label": "Variant",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "dark",
          "label": "Dark"
        }
      ],
      "default": "default"
    }
  ],
  "presets": [
    {
      "name": "Badge"
    }
  ]
}
{% endschema %}
