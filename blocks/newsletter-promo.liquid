{% assign newsletter_promo_form_id = 'NewsletterPromoForm-' | append: block.id %}

<div
  class="newsletter-promo newsletter-promo--{{ block.settings.image_position }}"
  style="--newsletter-promo-background: {{ block.settings.background_color }};"
 {{ block.shopify_attributes }}>
  <div class="newsletter-promo__content">
    {% render 'section-header',
      eyebrow: block.settings.eyebrow,
      heading: block.settings.heading,
      text: block.settings.description,
      alignment: 'left'
    %}

    {% render 'newsletter-form',
      id: newsletter_promo_form_id,
      class: 'newsletter-promo__form',
      row_class: 'newsletter-promo__row',
      button_label: block.settings.button_label,
      success_class: 'newsletter-promo__success',
      errors_class: 'newsletter-promo__errors'
    %}
  </div>

  {% if block.settings.image != blank %}
    {% render 'image',
      class: 'newsletter-promo__image',
      image: block.settings.image,
      alt: block.settings.heading,
      width: 1000,
      height: 750,
      crop: 'center',
      widths: '400, 650, 850, 1000',
      sizes: '(min-width: 990px) 44vw, 100vw'
    %}
  {% endif %}
</div>

{% stylesheet %}
  .newsletter-promo {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.8fr);
    gap: 2rem;
    align-items: center;
    padding: 2rem;
    border-radius: 8px;
    background-color: var(--newsletter-promo-background);
  }

  .newsletter-promo--left .newsletter-promo__content {
    order: 2;
  }

  .newsletter-promo__content {
    display: grid;
    gap: 1rem;
  }

  .newsletter-promo .section-header {
    margin-bottom: 0;
  }

  .newsletter-promo__form {
    display: grid;
    gap: 0.75rem;
  }

  .newsletter-promo__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.5rem;
  }

  .newsletter-promo input {
    min-height: 44px;
    min-width: 0;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .newsletter-promo button {
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background-color: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  .newsletter-promo__success,
  .newsletter-promo__errors {
    padding: 0.75rem 1rem;
    border-radius: 4px;
  }

  .newsletter-promo__success {
    border: 1px solid rgb(0, 128, 96);
    color: rgb(0, 128, 96);
  }

  .newsletter-promo__errors {
    border: 1px solid rgb(180, 38, 38);
    color: rgb(180, 38, 38);
  }

  .newsletter-promo__image img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 8px;
  }

  @media screen and (max-width: 749px) {
    .newsletter-promo {
      grid-template-columns: 1fr;
      padding: 1.25rem;
    }

    .newsletter-promo--left .newsletter-promo__content {
      order: initial;
    }

    .newsletter-promo__row {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter_promo",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Newsletter"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Get the latest drops and offers"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description",
      "default": "<p>Invite customers to subscribe with a stronger visual treatment than the compact newsletter section.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:labels.image_position",
      "options": [
        { "value": "right", "label": "t:options.position.right" },
        { "value": "left", "label": "t:options.position.left" }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Subscribe"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#f6f6f7"
    }
  ],
  "presets": [{ "name": "t:general.newsletter_promo" }]
}
{% endschema %}
