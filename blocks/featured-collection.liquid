{% assign featured_collection = block.settings.collection %}

<div class="featured-collection featured-collection--{{ block.settings.layout }}" {{ block.shopify_attributes }}>
  {% render 'section-header',
    eyebrow: block.settings.eyebrow,
    heading: block.settings.heading,
    text: block.settings.description,
    alignment: block.settings.alignment
  %}

  {% if featured_collection != blank and featured_collection.products_count > 0 %}
    <div class="featured-collection__products">
      {% for product in featured_collection.products limit: block.settings.product_limit %}
        {% render 'product-card',
          product: product,
          show_vendor: block.settings.show_vendor,
          show_badges: block.settings.show_badges,
          show_secondary_image: block.settings.show_secondary_image,
          enable_quick_add: block.settings.enable_quick_add
        %}
      {% endfor %}
    </div>

    {% if block.settings.button_label != blank %}
      <div class="featured-collection__footer">
        {% render 'main-button',
          label: block.settings.button_label,
          url: featured_collection.url,
          variant: block.settings.button_variant
        %}
      </div>
    {% endif %}
  {% elsif request.design_mode %}
    <p class="featured-collection__empty">{{ 'sections.featured_collection.empty' | t }}</p>
  {% endif %}
</div>

{% stylesheet %}
  .featured-collection {
    width: 100%;
  }

  .featured-collection__products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .featured-collection--slider .featured-collection__products {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 0.5rem;
  }

  .featured-collection--slider .product-card {
    flex: 0 0 min(280px, 80vw);
    scroll-snap-align: start;
  }

  .featured-collection__footer {
    display: flex;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .featured-collection__footer .main-button {
    margin-top: 0;
  }

  .featured-collection__empty {
    padding: 1rem;
    border: 1px dashed rgb(180, 180, 180);
    border-radius: 6px;
    color: rgb(92, 95, 98);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Featured collection"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "t:labels.product_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:labels.layout",
      "options": [
        { "value": "grid", "label": "t:options.layout.grid" },
        { "value": "slider", "label": "t:options.layout.slider" }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "t:labels.show_badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "t:labels.show_secondary_image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "label": "t:labels.enable_quick_add",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "View all"
    },
    {
      "type": "select",
      "id": "button_variant",
      "label": "t:labels.button_variant",
      "options": [
        { "value": "primary", "label": "t:general.primary" },
        { "value": "secondary", "label": "t:general.secondary" },
        { "value": "accent", "label": "t:general.accent" }
      ],
      "default": "secondary"
    }
  ],
  "presets": [{ "name": "t:general.featured_collection" }]
}
{% endschema %}
