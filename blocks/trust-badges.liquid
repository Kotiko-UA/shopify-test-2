<div class="trust-badges" {{ block.shopify_attributes }}>
  {% render 'section-header',
    heading: block.settings.heading,
    text: block.settings.description,
    alignment: block.settings.alignment
  %}

  <div class="trust-badges__grid">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .trust-badges { width: 100%; }

  .trust-badges__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .trust-badge {
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: white;
  }

  .trust-badge__icon {
    width: 48px;
  }

  .trust-badge__icon img {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .trust-badge h3 {
    margin: 0;
    font-size: 1rem;
  }

  .trust-badge__text {
    color: rgb(92, 95, 98);
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.trust_badges",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "center"
    }
  ],
  "blocks": [{ "type": "_trust-badge" }],
  "presets": [
    {
      "name": "t:general.trust_badges",
      "blocks": [
        { "type": "_trust-badge" },
        { "type": "_trust-badge" },
        { "type": "_trust-badge" }
      ]
    }
  ]
}
{% endschema %}
