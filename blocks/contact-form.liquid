{% comment %}
  Renders a reusable contact form section.

  Shopify sends contact form submissions to the merchant using the Liquid
  `form` tag with the `contact` type.

  https://shopify.dev/docs/storefronts/themes/customer-engagement/add-contact-form
{% endcomment %}

<script src="{{ 'contact-form.js' | asset_url }}" defer></script>

{% assign contact_form_id = 'ContactForm-' | append: block.id %}
{% assign contact_heading = block.settings.heading %}
{% assign contact_description = block.settings.description %}

{% if contact_heading == blank %}
  {% assign contact_heading = 'contact.heading' | t %}
{% endif %}

{% if contact_description == blank %}
  {% assign contact_description = 'contact.description_html' | t %}
{% endif %}
{% assign contact_success_text = 'contact.success' | t %}
{% capture contact_success_attributes %}
  data-contact-success
  data-redirect-url="{{ block.settings.success_redirect }}"
  data-redirect-delay="{{ block.settings.redirect_delay | times: 1000 }}"
{% endcapture %}

<div class="contact-form-section" {{ block.shopify_attributes }}>
  <div class="contact-form-section__header">
    {% if contact_heading != blank %}
      <h2>{{ contact_heading | escape }}</h2>
    {% endif %}

    {% if contact_description != blank %}
      <div class="contact-form-section__description">
        {{ contact_description }}
      </div>
    {% endif %}
  </div>

  {% form 'contact', id: contact_form_id, class: 'contact-form' %}
    {% render 'form-message',
      form: form,
      success_text: contact_success_text,
      success_class: 'contact-form__success',
      errors_class: 'contact-form__errors',
      success_attributes: contact_success_attributes
    %}

    <div class="contact-form__fields">
      {% content_for 'blocks' %}
    </div>

    <button class="contact-form__submit" type="submit">{{ 'contact.submit' | t }}</button>
  {% endform %}
</div>

{% stylesheet %}
  .contact-form-section {
    width: min(100%, 760px);
    margin-inline: auto;
  }

  .contact-form-section__header {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .contact-form-section__description {
    color: rgb(92, 95, 98);
    line-height: 1.6;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .contact-form__fields {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1rem;
  }

  .contact-form__fields > * {
    min-width: 0;
    grid-column: 1 / -1;
  }

  .contact-form__fields > :is(.contact-form__field--half, :has(> .contact-form__field--half)) {
    grid-column: span 3;
  }

  .contact-form__fields > :is(.contact-form__field--third, :has(> .contact-form__field--third)) {
    grid-column: span 2;
  }

  .contact-form__fields > :is(.contact-form__field--two-thirds, :has(> .contact-form__field--two-thirds)) {
    grid-column: span 4;
  }

  .contact-form__field--full {
    grid-column: 1 / -1;
  }

  .contact-form__field--half {
    grid-column: span 3;
  }

  .contact-form__field--third {
    grid-column: span 2;
  }

  .contact-form__field--two-thirds {
    grid-column: span 4;
  }

  .contact-form__field {
    display: grid;
    gap: 0.35rem;
  }

  .contact-form__field > label,
  .contact-form__fieldset legend {
    font-weight: 700;
  }

  .contact-form__fieldset {
    min-width: 0;
    padding: 0;
    border: 0;
  }

  .contact-form input:not([type='checkbox']):not([type='radio']),
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid rgb(180, 180, 180);
    border-radius: 4px;
  }

  .contact-form textarea {
    resize: vertical;
  }

  .contact-form__choices {
    display: grid;
    gap: 0.5rem;
  }

  .contact-form__choice,
  .contact-form__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .contact-form__choice {
    width: fit-content;
    cursor: pointer;
  }

  .contact-form__choice input,
  .contact-form__consent input {
    flex: 0 0 auto;
    width: 1rem;
    height: 1rem;
    margin-top: 0.2rem;
  }

  .contact-form__consent-label {
    cursor: pointer;
  }

  .contact-form__consent-label p {
    margin: 0;
  }

  .contact-form__success {
    padding: 0.75rem 1rem;
    border: 1px solid rgb(0, 128, 96);
    border-radius: 4px;
    color: rgb(0, 128, 96);
  }

  .contact-form__errors {
    padding: 0.75rem 1rem;
    border: 1px solid rgb(180, 38, 38);
    border-radius: 4px;
    color: rgb(180, 38, 38);
  }

  .contact-form__submit {
    justify-self: start;
    min-height: 44px;
    padding: 0.65rem 1rem;
    border: 1px solid rgb(20, 20, 20);
    border-radius: 4px;
    background: rgb(20, 20, 20);
    color: white;
    cursor: pointer;
  }

  @media screen and (max-width: 749px) {
    .contact-form__fields {
      grid-template-columns: minmax(0, 1fr);
    }

    .contact-form__fields > * {
      grid-column: 1 / -1;
    }

    .contact-form__field--half,
    .contact-form__field--third,
    .contact-form__field--two-thirds {
      grid-column: 1 / -1;
    }

    .contact-form__submit {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.contact_form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "url",
      "id": "success_redirect",
      "label": "t:labels.success_redirect"
    },
    {
      "type": "range",
      "id": "redirect_delay",
      "label": "t:labels.redirect_delay",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 2
    }
  ],
  "blocks": [{ "type": "_contact-input" }, { "type": "_contact-textarea" }, { "type": "_contact-select" }, { "type": "_contact-radio" }, { "type": "_contact-consent" }],
  "presets": [
    {
      "name": "t:general.contact_form"
    }
  ]
}
{% endschema %}
