<div class="collection-list" {{ block.shopify_attributes }}>
  {% render 'section-header',
    eyebrow: block.settings.eyebrow,
    heading: block.settings.heading,
    text: block.settings.description,
    alignment: block.settings.alignment
  %}

  <div class="collection-list__grid">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .collection-list { width: 100%; }

  .collection-list__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .collection-list-card {
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: white;
  }

  .collection-list-card__image img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .collection-list-card__content {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
  }

  .collection-list-card h3,
  .collection-list-card p {
    margin: 0;
  }

  .collection-list-card a {
    color: inherit;
    text-decoration: none;
  }

  .collection-list-card p {
    color: rgb(92, 95, 98);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection_list",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop collections"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:labels.description"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "t:labels.alignment",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [{ "type": "_collection-card" }],
  "presets": [
    {
      "name": "t:general.collection_list",
      "blocks": [
        { "type": "_collection-card" },
        { "type": "_collection-card" },
        { "type": "_collection-card" }
      ]
    }
  ]
}
{% endschema %}
