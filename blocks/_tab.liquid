{% doc %}
  Renders one tab trigger and a panel that accepts nested theme and app blocks.

  The tabs section moves the trigger into its tab list during initialization.

  @example
  {% content_for 'block', type: '_tab', id: 'tab' %}
{% enddoc %}

<div
  class="tabs__item"
  data-tab-item
  data-tab-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  <button
    id="TabButton-{{ section.id }}-{{ block.id }}"
    class="tabs__button"
    type="button"
    role="tab"
    aria-selected="false"
    aria-controls="TabPanel-{{ section.id }}-{{ block.id }}"
    tabindex="-1"
    data-tab-button
    data-tab-id="{{ block.id }}"
  >
    {{ block.settings.title | default: 'Tab' | escape }}
  </button>

  <div
    id="TabPanel-{{ section.id }}-{{ block.id }}"
    class="tabs__panel"
    role="tabpanel"
    aria-labelledby="TabButton-{{ section.id }}-{{ block.id }}"
    data-tab-panel
  >
    <div class="tabs__panel-content">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .tabs__item,
  .tabs__panel-content { min-width: 0; }
  .tabs__item { display: grid; gap: 0.75rem; }
  .tabs__item > .tabs__button { justify-self: start; }
  .tabs__button { flex: 0 0 auto; min-height: 40px; padding: 0.6rem 1rem; border: 1px solid color-mix(in srgb, var(--color-foreground), transparent 65%); border-radius: 4px; background: var(--color-background); color: var(--color-foreground); font: inherit; cursor: pointer; }
  .tabs__button:hover { border-color: var(--color-foreground); }
  .tabs__button--active { border-color: var(--color-foreground); background: var(--color-foreground); color: var(--color-background); }
  .tabs__button:focus-visible { outline: 2px solid currentColor; outline-offset: 3px; }
  .tabs__panel { padding-block: 1.25rem; border-top: 1px solid color-mix(in srgb, var(--color-foreground), transparent 78%); line-height: 1.6; }
  .tabs__panel-content { display: grid; gap: 1rem; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.tab",
  "blocks": [{ "type": "@theme" }, { "type": "@app" }],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Tab"
    }
  ],
  "presets": [
    {
      "name": "t:general.tab",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "text": "Add tab content.",
            "text_style": "text--normal",
            "alignment": "left"
          }
        }
      ]
    }
  ]
}
{% endschema %}
