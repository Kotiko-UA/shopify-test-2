{% assign field_id = 'ContactField-' | append: section.id | append: '-' | append: block.id %}
{% assign field_label = block.settings.label | default: 'Field' %}
{% assign field_name = block.settings.field_name | default: field_label %}
{% assign help_id = field_id | append: '-help' %}
{% if block.settings.input_type == 'email' %}{% assign field_name = 'email' %}{% endif %}

<div class="contact-form__field contact-form__field--{{ block.settings.width }}" {{ block.shopify_attributes }}>
  <label for="{{ field_id }}">{{ field_label | escape }}</label>
  <input id="{{ field_id }}" type="{{ block.settings.input_type }}" name="contact[{{ field_name | escape }}]" placeholder="{{ block.settings.placeholder | escape }}"{% if block.settings.help_text != blank %} aria-describedby="{{ help_id }}"{% endif %}{% if block.settings.pattern != blank %} pattern="{{ block.settings.pattern | escape }}"{% endif %}{% if block.settings.min != blank %} min="{{ block.settings.min | escape }}"{% endif %}{% if block.settings.max != blank %} max="{{ block.settings.max | escape }}"{% endif %}{% if block.settings.input_type == 'email' %} autocomplete="email" spellcheck="false" autocapitalize="off"{% endif %}{% if block.settings.required or block.settings.input_type == 'email' %} required{% endif %}>
  {% if block.settings.help_text != blank %}<small id="{{ help_id }}">{{ block.settings.help_text | escape }}</small>{% endif %}
</div>

{% stylesheet %}.contact-form__field { display: grid; gap: 0.35rem; }{% endstylesheet %}

{% schema %}
{
  "name": "t:general.input_field",
  "settings": [
    { "type": "text", "id": "label", "label": "t:labels.field_label", "default": "Your answer" },
    { "type": "text", "id": "field_name", "label": "t:labels.submission_field_name" },
    { "type": "select", "id": "input_type", "label": "t:labels.input_type", "options": [{ "value": "text", "label": "t:options.input_type.text" }, { "value": "email", "label": "t:options.input_type.email" }, { "value": "tel", "label": "t:options.input_type.tel" }, { "value": "number", "label": "t:options.input_type.number" }, { "value": "date", "label": "t:options.input_type.date" }, { "value": "url", "label": "t:options.input_type.url" }], "default": "text" },
    { "type": "text", "id": "placeholder", "label": "t:labels.placeholder" },
    { "type": "text", "id": "help_text", "label": "t:labels.help_text" },
    { "type": "text", "id": "pattern", "label": "t:labels.validation_pattern" },
    { "type": "text", "id": "min", "label": "t:labels.minimum_value" },
    { "type": "text", "id": "max", "label": "t:labels.maximum_value" },
    { "type": "select", "id": "width", "label": "t:labels.field_width", "options": [{ "value": "full", "label": "t:options.field_width.full" }, { "value": "half", "label": "t:options.field_width.half" }, { "value": "third", "label": "t:options.field_width.third" }, { "value": "two-thirds", "label": "t:options.field_width.two_thirds" }], "default": "full" },
    { "type": "checkbox", "id": "required", "label": "t:labels.required_field", "default": false }
  ],
  "presets": [{ "name": "t:general.input_field" }]
}
{% endschema %}
