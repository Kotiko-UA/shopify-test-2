<div class="logo-marquee__item" {{ block.shopify_attributes }}>
  {% if block.settings.link != blank %}<a href="{{ block.settings.link }}" aria-label="{{ block.settings.title | escape }}">{% endif %}
  {% if block.settings.logo != blank %}
    {% render 'image', class: 'logo-marquee__logo', image: block.settings.logo, alt: block.settings.title, width: 240, widths: '120, 180, 240', sizes: '160px' %}
  {% elsif block.settings.title != blank %}
    <span class="logo-marquee__text">{{ block.settings.title | escape }}</span>
  {% endif %}
  {% if block.settings.link != blank %}</a>{% endif %}
</div>

{% stylesheet %}
  .logo-marquee__item { display: grid; place-items: center; min-width: 180px; padding: 1.25rem 2rem; }
  .logo-marquee__logo img { max-height: 56px; object-fit: contain; }
  .logo-marquee__text { font-weight: 700; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.logo",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "t:labels.logo" },
    { "type": "text", "id": "title", "label": "t:labels.title", "default": "Brand" },
    { "type": "url", "id": "link", "label": "t:labels.link" }
  ],
  "presets": [{ "name": "t:general.logo" }]
}
{% endschema %}
