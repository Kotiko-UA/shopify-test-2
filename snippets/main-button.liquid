<a class="main-button" href="{{url}}">{{ label }}</a>

{%- stylesheet -%}
  .main-button {
    display: inline-flex;
    width: fit-content;
    margin-top: 1.5rem;
    padding: 10px 16px;
    border-radius: 4px;
    background-color: rgb(32, 34, 35);
    color: rgb(255, 255, 255);
    text-decoration: none;
    line-height: 1.2;
  }
{%- endstylesheet -%}
