{% doc %}
  Renders an accessible star rating.

  @param {number} rating - Rating from 0 to 5
  @param {string} [class] - Optional extra class
  @param {string} [label] - Accessible label
{% enddoc %}

{% liquid
  assign rating_stars_class = 'rating-stars'
  if class != blank
    assign rating_stars_class = rating_stars_class | append: ' ' | append: class
  endif

  assign rating_stars_label = label
  if rating_stars_label == blank
    assign rating_stars_label = rating | append: ' out of 5'
  endif
%}

{% if rating > 0 %}
  <div class="{{ rating_stars_class }}" aria-label="{{ rating_stars_label | escape }}">
    {% for index in (1..rating) %}
      <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18">
        <path fill="currentColor" d="m12 2.5 2.9 5.9 6.5.9-4.7 4.6 1.1 6.5-5.8-3-5.8 3 1.1-6.5L2.6 9.3l6.5-.9L12 2.5Z"/>
      </svg>
    {% endfor %}
  </div>
{% endif %}

{% stylesheet %}
  .rating-stars {
    display: flex;
    gap: 0.15rem;
    font-weight: 700;
  }
{% endstylesheet %}
