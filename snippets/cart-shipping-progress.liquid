{% doc %}
  Renders free-shipping progress for a cart surface.

  @param {number} threshold - Free-shipping threshold in the store currency.
  @param {string} [class] - Optional wrapper class.
{% enddoc %}

{% assign threshold_cents = threshold | times: 100 %}
{% if threshold_cents > 0 %}
  {% assign remaining = threshold_cents | minus: cart.total_price %}
  {% assign progress = cart.total_price | times: 100 | divided_by: threshold_cents %}
  {% assign remaining_money = remaining | money %}
  {% if progress > 100 %}{% assign progress = 100 %}{% endif %}

  <div class="cart-shipping-progress {{ class }}" role="status">
    <p>
      {% if remaining > 0 %}
        {{ 'cart.free_shipping_remaining' | t: amount: remaining_money }}
      {% else %}
        {{ 'cart.free_shipping_reached' | t }}
      {% endif %}
    </p>
    <div class="cart-shipping-progress__track" aria-hidden="true">
      <span style="width: {{ progress }}%"></span>
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .cart-shipping-progress {
    display: grid;
    gap: 0.5rem;
  }
  .cart-shipping-progress p { margin: 0; font-weight: 700; }
  .cart-shipping-progress__track { height: 0.5rem; overflow: hidden; border-radius: 999px; background: rgb(220, 220, 220); }
  .cart-shipping-progress__track span { display: block; height: 100%; border-radius: inherit; background: rgb(0, 128, 96); transition: width 220ms ease; }
  @media (prefers-reduced-motion: reduce) { .cart-shipping-progress__track span { transition: none; } }
{% endstylesheet %}
