{% doc %}
  Renders a responsive image that might be wrapped in a link.

  When `width`, `height` and `crop` are provided, the image will be rendered
  with a fixed aspect ratio.

  Serves as an example of how to use the `image_url` filter and `image_tag` filter
  as well as how you can use LiquidDoc to document your code.

  @param {image} image - The image to be rendered
  @param {string} [url] - An optional destination URL for the image
  @param {string} [class] - Optional class to be added to the image wrapper
  @param {string} [alt] - Optional image alt text
  @param {string} [link_label] - Optional accessible label when the image is wrapped in a link
  @param {string} [loading] - Image loading strategy, usually lazy or eager
  @param {string} [fetchpriority] - Browser fetch priority, usually high for the main above-the-fold image
  @param {string} [widths] - Comma-separated responsive image widths for srcset generation
  @param {string} [sizes] - Browser size hint that describes the rendered image slot
  @param {number} [width] - The highest resolution width of the image to be rendered
  @param {number} [height] - The highest resolution height of the image to be rendered
  @param {string} [crop] - The crop position of the image
  @param {boolean} [decorative] - Whether the image is decorative and should have empty alt text

  @example
  {% render 'image', image: product.featured_image %}
  {% render 'image', image: product.featured_image, url: product.url %}
  {% render 'image',
    class: 'product__image',
    image: product.featured_image,
    url: product.url,
    width: 1200,
    height: 800,
    crop: 'center',
  %}
{% enddoc %}

{% liquid
  unless height
    assign width = width | default: image.width
  endunless

  if url
    assign wrapper = 'a'
  else
    assign wrapper = 'div'
  endif

  if decorative
    assign image_alt = ''
  else
    assign image_alt = alt | default: image.alt | default: ''
  endif

  assign image_loading = loading | default: 'lazy'
  assign image_fetchpriority = fetchpriority | default: ''
  assign image_widths = widths | default: ''
  assign image_sizes = sizes | default: ''
%}

<{{ wrapper }}
  class="image {{ class }}"
  {% if url %}
    href="{{ url }}"
    {% if link_label != blank %}
      aria-label="{{ link_label | escape }}"
    {% endif %}
  {% endif %}
>
  {% if image_fetchpriority != blank and image_widths != blank and image_sizes != blank %}
    {{
      image
      | image_url: width: width, height: height, crop: crop
      | image_tag:
        alt: image_alt,
        loading: image_loading,
        fetchpriority: image_fetchpriority,
        widths: image_widths,
        sizes: image_sizes
    }}
  {% elsif image_fetchpriority != blank %}
    {{
      image
      | image_url: width: width, height: height, crop: crop
      | image_tag: alt: image_alt, loading: image_loading, fetchpriority: image_fetchpriority
    }}
  {% elsif image_widths != blank and image_sizes != blank %}
    {{
      image
      | image_url: width: width, height: height, crop: crop
      | image_tag: alt: image_alt, loading: image_loading, widths: image_widths, sizes: image_sizes
    }}
  {% else %}
    {{
      image
      | image_url: width: width, height: height, crop: crop
      | image_tag: alt: image_alt, loading: image_loading
    }}
  {% endif %}
</{{ wrapper }}>

{% stylesheet %}
  .image {
    display: block;
    position: relative;
    overflow: hidden;
    width: 100%;
    height: auto;
  }

  .image > img {
    width: 100%;
    height: auto;
  }
{% endstylesheet %}
