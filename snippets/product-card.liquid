{% doc %}
  Renders a product card.

  @param {product} product - Product to display.
  @param {boolean} [show_vendor] - Whether to display the product vendor.

  @example
  {% render 'product-card', product: product %}
{% enddoc %}

<div class="product-card">
  {% if product.featured_image %}
    {% render 'image',
      class: 'product-card__image',
      image: product.featured_image,
      url: product.url,
      link_label: product.title,
      decorative: true,
      width: 600,
      height: 600,
      crop: 'center',
      widths: '200, 300, 400, 500, 600',
      sizes: '(min-width: 1200px) 220px, (min-width: 750px) 33vw, 50vw'
    %}
  {% endif %}
  <div class="product-card__content">
    {% if show_vendor and product.vendor != blank %}
      <p class="product-card__vendor">{{ product.vendor }}</p>
    {% endif %}
    <p class="product-card__title">{{ product.title | escape | link_to: product.url }}</p>
    <div class="product-card__price">
      <span>{{ product.price | money }}</span>

      {% if product.compare_at_price > product.price %}
        <s>{{ product.compare_at_price | money }}</s>
      {% endif %}
    </div>
  </div>
</div>
{% stylesheet %}
  .product-card {
    height: 100%;
    overflow: hidden;
    border: 1px solid rgb(220, 220, 220);
    border-radius: 8px;
    background-color: white;
  }

  .product-card__image img {
    aspect-ratio: 1;
    object-fit: cover;
  }

  .product-card__content {
    display: grid;
    gap: 0.5rem;
    padding: 1rem;
  }

  .product-card__vendor {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: rgb(92, 95, 98);
  }

  .product-card__title {
    margin: 0;
    font-weight: 700;
    line-height: 1.3;
  }

  .product-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .product-card__price {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .product-card__price s {
    opacity: 0.6;
  }
{% endstylesheet %}
